---
import type { Services6Props } from "./schema";
import PeakSection from "../PeakSection.astro";

const node = (Astro.props.node ?? {}) as Services6Props;
const { badge, title, description, buttonText, buttonUrl = "#", cards, accent = "#16a6da" } = node;

const cardList = Array.isArray(cards) ? cards.filter((c) => c?.image || c?.label) : [];
const arrow =
	'<path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M4 12h15m-6-6 6 6-6 6"/>';
const heart =
	'<path fill="currentColor" d="M12 20s-6.5-4.2-6.5-9A3.5 3.5 0 0 1 12 8.2 3.5 3.5 0 0 1 18.5 11c0 4.8-6.5 9-6.5 9z"/>';
---

<PeakSection node={node}>
	<div class="ps6" style={`--accent:${accent}`}>
		<aside class="ps6__left">
			{badge && (
				<span class="ps6__badge">
					<svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" set:html={heart} />
					{badge}
				</span>
			)}
			{title && <h2 class="ps6__title">{title}</h2>}
			{description && <p class="ps6__desc">{description}</p>}
			{buttonText && (
				<a class="ps6__btn" href={buttonUrl}>
					<span>{buttonText}</span>
					<span class="ps6__btn-ico">
						<svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" set:html={arrow} />
					</span>
				</a>
			)}
		</aside>

		{cardList.length > 0 && (
			<div class="ps6__grid">
				{cardList.map((c) => (
					<a class="ps6__item" href={c.url || undefined}>
						<div class="ps6__media">
							{c.image && <img src={c.image} alt={c.alt ?? c.label ?? ""} loading="lazy" />}
						</div>
						<div class="ps6__cap">
							{c.label && <span class="ps6__label">{c.label}</span>}
							<svg class="ps6__cap-arrow" viewBox="0 0 24 24" width="26" height="26" aria-hidden="true" set:html={arrow} />
						</div>
					</a>
				))}
			</div>
		)}
	</div>
</PeakSection>

<style>
	.ps6 {
		display: grid;
		grid-template-columns: minmax(280px, 0.85fr) 1.45fr;
		gap: clamp(1.5rem, 4vw, 4rem);
		align-items: start;
		color: #0f2a39;
	}

	/* Sticky left intro — stays pinned while the right grid scrolls. */
	.ps6__left {
		position: sticky;
		top: clamp(1.5rem, 6vh, 3rem);
		align-self: start;
	}
	.ps6__badge {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.55rem 1.1rem;
		background: #e3f3fb;
		color: #0f2a39;
		border-radius: 999px;
		font-size: 0.9rem;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}
	.ps6__badge svg { color: var(--accent); }
	.ps6__title {
		margin: 1.5rem 0 0;
		font-weight: 700;
		letter-spacing: -0.02em;
		line-height: 1.05;
		font-size: calc(clamp(2.6rem, 4.5vw, 4rem) * var(--peak-font-scale, 1));
	}
	.ps6__desc {
		margin: 1.75rem 0 0;
		color: #5f6b73;
		font-size: calc(1.1rem * var(--peak-font-scale, 1));
		line-height: 1.6;
		max-width: 38ch;
	}
	.ps6__btn {
		display: inline-flex;
		align-items: center;
		gap: 1rem;
		margin-top: 2rem;
		padding: 0.55rem 0.55rem 0.55rem 1.75rem;
		border-radius: 999px;
		background: linear-gradient(95deg, color-mix(in srgb, var(--accent) 78%, white), var(--accent));
		color: #fff;
		font-weight: 700;
		font-size: 1.1rem;
		text-decoration: none;
	}
	.ps6__btn-ico {
		display: grid;
		place-items: center;
		width: 40px;
		height: 40px;
		border-radius: 50%;
		background: #fff;
		color: var(--accent);
	}

	/* Right scrolling grid. */
	.ps6__grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: clamp(1.25rem, 2.5vw, 2.25rem) clamp(1.25rem, 2vw, 2rem);
	}
	.ps6__item { display: block; text-decoration: none; color: inherit; }
	.ps6__media {
		border-radius: 18px;
		overflow: hidden;
		aspect-ratio: 5 / 4;
		background: #e8edf0;
	}
	.ps6__media img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.4s ease;
	}
	.ps6__item:hover .ps6__media img { transform: scale(1.04); }
	.ps6__cap {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 1rem 0.4rem 0.5rem;
	}
	.ps6__label {
		font-weight: 700;
		letter-spacing: -0.01em;
		font-size: calc(clamp(1.25rem, 1.6vw, 1.6rem) * var(--peak-font-scale, 1));
	}
	.ps6__cap-arrow { flex: 0 0 auto; color: #9aa6ad; transition: color 0.25s ease, transform 0.25s ease; }
	.ps6__item:hover .ps6__cap-arrow { color: var(--accent); transform: translateX(4px); }

	@media (max-width: 900px) {
		.ps6 { grid-template-columns: 1fr; }
		.ps6__left { position: static; }
	}
	@media (max-width: 560px) {
		.ps6__grid { grid-template-columns: 1fr; }
	}
</style>
