---
import type { Hero25Props } from "./schema";
import PeakSection from "../PeakSection.astro";

const node = (Astro.props.node ?? {}) as Hero25Props;
const {
	title,
	subtitle,
	stars = 5,
	reviewsText,
	button1Text,
	button1Url,
	button2Text,
	button2Url,
	videoUrl,
	poster,
	posterAlt,
	accent = "#f43f5e",
} = node;
const secNode = { ...node, width: (node as any).width || "bleed" };
const full = Math.max(0, Math.min(5, Math.round(Number(stars) || 0)));
---

<PeakSection node={secNode} defaultWidth="bleed">
	<div class="hv">
		<div class="hv__bg">
			{
				videoUrl ? (
					<video class="hv__media" autoplay muted loop playsinline preload="auto" poster={poster ?? undefined}>
						<source src={videoUrl} type="video/mp4" />
					</video>
				) : poster ? (
					<img class="hv__media" src={poster} alt={posterAlt ?? ""} />
				) : null
			}
		</div>
		<div class="hv__overlay"></div>

		<div class="hv__inner">
			{title && <h1 class="hv__title">{title}</h1>}
			{subtitle && <p class="hv__subtitle">{subtitle}</p>}
			{
				(full > 0 || reviewsText) && (
					<div class="hv__rating">
						{full > 0 && (
							<span class="hv__stars" aria-label={`${full} out of 5 stars`}>
								{"★".repeat(full)}
							</span>
						)}
						{reviewsText && <span class="hv__reviews">{reviewsText}</span>}
					</div>
				)
			}
			<div class="hv__cta">
				{
					button1Text && (
						<a class="hv__btn hv__btn--primary" href={button1Url} style={`background:${accent}`}>
							{button1Text}
						</a>
					)
				}
				{
					button2Text && (
						<a class="hv__btn hv__btn--dark" href={button2Url}>
							{button2Text}
						</a>
					)
				}
			</div>
		</div>
	</div>
</PeakSection>

<style>
	.hv {
		position: relative;
		min-height: clamp(560px, 88vh, 900px);
		display: flex;
		overflow: hidden;
		color: #14181f;
		text-align: center;
	}
	.hv__bg,
	.hv__overlay {
		position: absolute;
		inset: 0;
	}
	.hv__media {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}
	/* Light wash so the dark headline stays readable over the video. */
	.hv__overlay {
		background: linear-gradient(
			180deg,
			rgba(255, 255, 255, 0.8) 0%,
			rgba(255, 255, 255, 0.55) 45%,
			rgba(255, 255, 255, 0.72) 100%
		);
	}
	.hv__inner {
		position: relative;
		margin: auto;
		width: 100%;
		max-width: var(--peak-wide, 1180px);
		padding: clamp(3rem, 7vw, 6rem) var(--peak-gutter, 1.5rem);
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.5rem;
	}
	.hv__title {
		margin: 0;
		font-size: calc(clamp(2.25rem, 5vw, 4rem) * var(--peak-font-scale, 1));
		font-weight: 800;
		line-height: 1.08;
		letter-spacing: -0.01em;
		max-width: 20ch;
	}
	.hv__subtitle {
		margin: 0;
		font-size: calc(clamp(1.1rem, 2vw, 1.5rem) * var(--peak-font-scale, 1));
		color: #2c333d;
		max-width: 42ch;
	}
	.hv__rating {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		font-weight: 600;
	}
	.hv__stars {
		color: #f5b50a;
		letter-spacing: 2px;
		font-size: 1.25rem;
	}
	.hv__cta {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		justify-content: center;
		margin-top: 0.5rem;
	}
	.hv__btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 1rem 1.9rem;
		border-radius: 10px;
		font-weight: 700;
		font-size: 1.05rem;
		text-decoration: none;
	}
	.hv__btn--primary {
		color: #fff;
	}
	.hv__btn--dark {
		background: #1f2a37;
		color: #fff;
	}
</style>
