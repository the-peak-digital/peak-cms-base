---
import type { Hero28Props } from "./schema";
import PeakSection from "../PeakSection.astro";

const node = (Astro.props.node ?? {}) as Hero28Props;
const {
	image,
	imageAlt,
	eyebrow,
	title,
	offer,
	button1Text,
	button1Url,
	button2Text,
	button2Url,
	features = [],
	socials = [],
} = node;
const secNode = { ...node, width: (node as any).width || "bleed" };
const feat = Array.isArray(features) ? features.filter((f: any) => f?.title || f?.text) : [];
const soc = Array.isArray(socials) ? socials.filter((s: any) => s?.icon || s?.url) : [];

// Clean line icons (Feather-style). The `icon` field can be one of these names —
// e.g. facebook / instagram / phone / mail / map / visualizer / showroom — which
// renders the SVG; anything else falls back to the raw text (so emoji still works).
const ICONS: Record<string, string> = {
	facebook: '<path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>',
	instagram:
		'<rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>',
	phone:
		'<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.8 12.8 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.8 12.8 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>',
	mail: '<rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>',
	map: '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>',
	visualizer:
		'<rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.09-3.09a2 2 0 0 0-2.82 0L6 21"/>',
	showroom: '<rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/>',
};
const svg = (name: string) =>
	name && ICONS[name]
		? `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${ICONS[name]}</svg>`
		: "";
---

<PeakSection node={secNode} defaultWidth="bleed">
	<div class="hg">
		{image && <img class="hg__bg" src={image} alt={imageAlt ?? ""} loading="eager" />}
		<div class="hg__overlay"></div>

		<div class="hg__inner">
			<div class="hg__content">
				{eyebrow && <p class="hg__eyebrow">{eyebrow}</p>}
				{title && <h1 class="hg__title">{title}</h1>}
				{
					offer && (
						<p class="hg__offer">
							<span class="hg__gem" aria-hidden="true">
								◆
							</span>
							{offer}
						</p>
					)
				}
				<div class="hg__cta">
					{button1Text && <a class="hg__btn hg__btn--dark" href={button1Url}>{button1Text}</a>}
					{button2Text && <a class="hg__btn hg__btn--light" href={button2Url}>{button2Text}</a>}
				</div>
			</div>

			{
				feat.length > 0 && (
					<div class="hg__features">
						{feat.map((f: any) => (
							<div class="hg__feature">
								{f.icon &&
									(svg(f.icon) ? (
										<span class="hg__feature-icon" set:html={svg(f.icon)} />
									) : (
										<span class="hg__feature-icon">{f.icon}</span>
									))}
								<div>
									{f.title && <h3 class="hg__feature-title">{f.title}</h3>}
									{f.text && <p class="hg__feature-text">{f.text}</p>}
								</div>
							</div>
						))}
					</div>
				)
			}
		</div>

		{
			soc.length > 0 && (
				<nav class="hg__social" aria-label="Social links">
					{soc.map((s: any) =>
						svg(s.icon) ? (
							<a class="hg__social-link" href={s.url || "#"} set:html={svg(s.icon)} />
						) : (
							<a class="hg__social-link" href={s.url || "#"}>
								{s.icon}
							</a>
						),
					)}
				</nav>
			)
		}
	</div>
</PeakSection>

<style>
	.hg {
		position: relative;
		min-height: clamp(620px, 92vh, 1000px);
		display: flex;
		overflow: hidden;
		color: #fff;
	}
	.hg__bg,
	.hg__overlay {
		position: absolute;
		inset: 0;
	}
	.hg__bg {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
	/* Dark wash: heavier on the left (text) and along the bottom (feature row). */
	.hg__overlay {
		background:
			linear-gradient(90deg, rgba(8, 9, 11, 0.82) 0%, rgba(8, 9, 11, 0.55) 45%, rgba(8, 9, 11, 0.28) 100%),
			linear-gradient(0deg, rgba(8, 9, 11, 0.6) 0%, rgba(8, 9, 11, 0) 38%);
	}
	.hg__inner {
		position: relative;
		width: 100%;
		max-width: var(--peak-wide, 1180px);
		margin-inline: auto;
		padding: clamp(3rem, 6vw, 5.5rem) var(--peak-gutter, 1.5rem);
		display: grid;
		grid-template-rows: 1fr auto;
		gap: clamp(2rem, 4vw, 3rem);
	}
	.hg__content {
		align-self: center;
		max-width: 62ch;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 1.5rem;
	}
	.hg__eyebrow {
		margin: 0;
		text-transform: uppercase;
		letter-spacing: 0.18em;
		font-size: 0.9rem;
		font-weight: 600;
		color: #e6e6e6;
	}
	.hg__title {
		margin: 0;
		max-width: 16ch;
		font-size: calc(clamp(2.5rem, 5.5vw, 4.5rem) * var(--peak-font-scale, 1));
		font-weight: 800;
		line-height: 1.04;
		text-shadow: 0 2px 24px rgba(0, 0, 0, 0.35);
	}
	.hg__offer {
		margin: 0;
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		font-size: calc(1.25rem * var(--peak-font-scale, 1));
	}
	.hg__gem {
		color: #f5c518;
	}
	.hg__cta {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		margin-top: 0.5rem;
	}
	.hg__btn {
		display: inline-flex;
		align-items: center;
		padding: 1rem 1.75rem;
		border-radius: 4px;
		font-weight: 700;
		font-size: 1rem;
		text-decoration: none;
	}
	.hg__btn--dark {
		background: #111;
		color: #fff;
	}
	.hg__btn--light {
		background: #fff;
		color: #111;
	}
	.hg__features {
		align-self: end;
		justify-content: flex-end;
		display: flex;
		flex-wrap: wrap;
		gap: clamp(2rem, 5vw, 4rem);
		padding-right: clamp(0px, 4vw, 4rem);
	}
	.hg__feature {
		display: flex;
		gap: 0.9rem;
		max-width: 340px;
		align-items: flex-start;
	}
	.hg__feature-icon {
		flex: 0 0 auto;
		color: #fff;
		opacity: 0.95;
	}
	.hg__feature-icon :global(svg) {
		width: 28px;
		height: 28px;
		display: block;
	}
	.hg__feature-title {
		margin: 0 0 0.3rem;
		font-size: 1.2rem;
		font-weight: 700;
	}
	.hg__feature-text {
		margin: 0;
		font-size: 0.95rem;
		color: #dcdcdc;
		line-height: 1.45;
	}
	.hg__social {
		position: absolute;
		right: clamp(1rem, 2vw, 2rem);
		top: 50%;
		transform: translateY(-50%);
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}
	.hg__social-link {
		width: 40px;
		height: 40px;
		border-radius: 50%;
		background: #111;
		color: #fff;
		display: flex;
		align-items: center;
		justify-content: center;
		text-decoration: none;
		font-size: 1.05rem;
	}
	.hg__social-link :global(svg) {
		width: 18px;
		height: 18px;
	}
	@media (max-width: 820px) {
		.hg__social {
			display: none;
		}
		.hg__title {
			font-size: 2.25rem;
		}
		.hg__features {
			justify-content: flex-start;
		}
	}
</style>
