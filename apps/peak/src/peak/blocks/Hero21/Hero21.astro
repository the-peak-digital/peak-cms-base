---
import type { Hero21Props } from "./schema";
import PeakSection from "../PeakSection.astro";

const node = (Astro.props.node ?? {}) as Hero21Props;
const {
	logo, slogan, image, imageAlt, address, email, phone, ctaText, ctaUrl,
	awardYear, awardText, eyebrow, eyebrowSub, links, title, titleAccent,
} = node;
const linkList = Array.isArray(links) ? links.filter((l) => l?.label) : [];
const addressLines = (address ?? "").split("\n").filter(Boolean);
---

<PeakSection node={node}>
	<div class="hm">
		{image && <img class="hm__bg" src={image} alt={imageAlt ?? ""} loading="eager" />}
		<div class="hm__veil"></div>

		<!-- Final hero content (visible by default; fades in after the curtain when animated) -->
		<div class="hm__ui">
			<header class="hm__top">
				{logo && <span class="hm__logo hm__reveal" style="--i:0">{logo}</span>}
				{addressLines.length > 0 && (
					<address class="hm__addr hm__reveal" style="--i:1">{addressLines.map((l) => <span>{l}</span>)}</address>
				)}
				{(email || phone) && (
					<div class="hm__contact hm__reveal" style="--i:2">
						{email && <span>{email}</span>}
						{phone && <span>{phone}</span>}
					</div>
				)}
				{ctaText && (
					<a class="hm__cta hm__reveal" style="--i:3" href={ctaUrl}>
						<span>{ctaText}</span>
						<span class="hm__cta-ico" aria-hidden="true">
							<svg viewBox="0 0 24 24" width="16" height="16"><path fill="none" stroke="#1a1a1a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 6l6 6-6 6"/></svg>
						</span>
					</a>
				)}
				<span class="hm__menu hm__reveal" style="--i:4" aria-hidden="true"><i></i><i></i></span>
			</header>

			<div class="hm__mid">
				<div class="hm__award hm__reveal" style="--i:5">
					<span class="hm__award-year">{awardYear}</span>
					<span class="hm__award-mark">int</span>
					<span class="hm__award-text">{awardText}</span>
				</div>
				{(eyebrow || eyebrowSub) && (
					<div class="hm__eyebrow hm__reveal" style="--i:6">
						{eyebrow && <span class="hm__eyebrow-1">{eyebrow}</span>}
						{eyebrowSub && <span class="hm__eyebrow-2">{eyebrowSub}</span>}
					</div>
				)}
				{linkList.length > 0 && (
					<ul class="hm__links hm__reveal" style="--i:7">{linkList.map((l) => <li>{l.label}</li>)}</ul>
				)}
			</div>

			{(title || titleAccent) && (
				<h1 class="hm__title hm__reveal" style="--i:8">
					{title}{titleAccent && <> <span class="hm__title-accent">{titleAccent}</span></>}
				</h1>
			)}
		</div>

		<!-- Intro curtain (only shown while animating) -->
		<div class="hm__curtain" aria-hidden="true">
			<span class="hm__panel hm__panel--l"></span>
			<span class="hm__panel hm__panel--m"></span>
			<span class="hm__panel hm__panel--r"></span>
			<span class="hm__line hm__line--1"></span>
			<span class="hm__line hm__line--2"></span>
			<div class="hm__intro">
				{logo && <span class="hm__intro-logo">{logo}</span>}
				{slogan && <span class="hm__intro-slogan">{slogan}</span>}
			</div>
		</div>
	</div>
</PeakSection>

<style>
	.hm { position: relative; overflow: hidden; border-radius: 22px; min-height: clamp(620px, 94vh, 1040px); color: #fff; }
	.hm__bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
	.hm__veil { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(20,18,15,0.28) 0%, rgba(20,18,15,0.05) 35%, rgba(20,18,15,0.18) 100%); }

	.hm__ui { position: relative; min-height: inherit; padding: clamp(1.5rem, 3vw, 2.75rem); display: flex; flex-direction: column; }

	/* top bar */
	.hm__top { display: grid; grid-template-columns: auto 1fr auto auto auto; align-items: start; gap: clamp(1rem, 3vw, 3rem); }
	.hm__logo { font-weight: 800; letter-spacing: 0.08em; font-size: 1.3rem; }
	.hm__addr, .hm__contact { display: flex; flex-direction: column; gap: 0.15rem; font-size: 0.95rem; line-height: 1.4; opacity: 0.92; }
	.hm__addr span:first-child, .hm__contact span:first-child { font-weight: 600; }
	.hm__cta { display: inline-flex; align-items: center; gap: 1rem; padding: 0.5rem 0.5rem 0.5rem 1.5rem; border: 1px solid rgba(255,255,255,0.4); border-radius: 999px; color: #fff; text-decoration: none; }
	.hm__cta-ico { display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; border-radius: 50%; background: #f5c518; }
	.hm__menu { display: inline-flex; flex-direction: column; justify-content: center; gap: 5px; width: 42px; height: 42px; }
	.hm__menu i { display: block; height: 2px; background: #fff; }

	/* mid row */
	.hm__mid { position: relative; flex: 1; }
	.hm__award { position: absolute; top: 38%; left: 8%; display: grid; grid-template-columns: auto auto; grid-template-rows: auto auto; column-gap: 0.5rem; align-items: center; font-size: 0.85rem; line-height: 1.1; }
	.hm__award-year { grid-column: 2; opacity: 0.85; }
	.hm__award-mark { grid-row: 1 / span 2; grid-column: 1; font-weight: 800; font-size: 1.5rem; }
	.hm__award-text { grid-column: 2; font-weight: 600; }
	.hm__eyebrow { position: absolute; top: 52%; left: 8%; display: flex; flex-direction: column; gap: 0.35rem; font-size: 1.35rem; }
	.hm__eyebrow-2 { color: #d8c7a8; }
	.hm__links { position: absolute; top: 50%; right: 6%; margin: 0; padding: 0; list-style: none; display: flex; flex-direction: column; gap: 0.4rem; font-size: 1.05rem; }

	.hm__title { font-size: calc(clamp(3rem, 8.5vw, 8.5rem) * var(--peak-font-scale, 1)); font-weight: 700; line-height: 0.95; letter-spacing: -0.02em; margin: 0; max-width: 16ch; }
	.hm__title-accent { color: rgba(232,220,196,0.65); }

	/* reveal animation for content */
	.hm.is-anim .hm__reveal { opacity: 0; transform: translateY(16px); }
	.hm.is-anim.is-open .hm__reveal { animation: hm-in 0.7s cubic-bezier(0.22,1,0.36,1) both; animation-delay: calc(var(--i, 0) * 0.07s); }
	@keyframes hm-in { to { opacity: 1; transform: none; } }

	/* curtain */
	.hm__curtain { display: none; }
	.hm.is-anim .hm__curtain { display: block; position: absolute; inset: 0; z-index: 5; pointer-events: none; }
	.hm__panel { position: absolute; top: 0; height: 100%; width: 33.34%; background: #f4f2ee; }
	.hm__panel--l { left: 0; animation: hm-up 1s cubic-bezier(0.76,0,0.24,1) 1.05s forwards; }
	.hm__panel--m { left: 33.33%; animation: hm-down 1s cubic-bezier(0.76,0,0.24,1) 1.2s forwards; }
	.hm__panel--r { left: 66.66%; animation: hm-down 1s cubic-bezier(0.76,0,0.24,1) 1.05s forwards; }
	@keyframes hm-up { to { transform: translateY(-101%); } }
	@keyframes hm-down { to { transform: translateY(101%); } }

	.hm__line { position: absolute; top: 0; width: 1px; height: 100%; background: rgba(255,255,255,0.18); transform: scaleY(0); transform-origin: center; opacity: 0; animation: hm-line 0.8s ease 1.7s forwards; }
	.hm__line--1 { left: 33.33%; }
	.hm__line--2 { left: 66.66%; }
	@keyframes hm-line { to { transform: scaleY(1); opacity: 1; } }

	.hm__intro { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.75rem; color: #1a1a1a; animation: hm-intro-out 0.5s ease 1.1s forwards; }
	.hm__intro-logo { font-weight: 800; letter-spacing: 0.1em; font-size: 2rem; animation: hm-sep-up 0.7s cubic-bezier(0.22,1,0.36,1) 0.4s both; }
	.hm__intro-slogan { font-size: 1.1rem; color: #6b6b6b; animation: hm-sep-down 0.7s cubic-bezier(0.22,1,0.36,1) 0.4s both; }
	@keyframes hm-sep-up { from { transform: translateY(18px); opacity: 0; } to { transform: translateY(-6px); opacity: 1; } }
	@keyframes hm-sep-down { from { transform: translateY(-18px); opacity: 0; } to { transform: translateY(6px); opacity: 1; } }
	@keyframes hm-intro-out { to { opacity: 0; } }

	@media (prefers-reduced-motion: reduce) {
		.hm.is-anim .hm__curtain { display: none; }
		.hm.is-anim .hm__reveal { opacity: 1 !important; transform: none !important; animation: none !important; }
	}

	@media (max-width: 900px) {
		.hm__top { grid-template-columns: auto auto; gap: 1rem; }
		.hm__addr, .hm__contact, .hm__menu { display: none; }
		.hm__award, .hm__eyebrow, .hm__links { position: static; margin-top: 1rem; }
		.hm__mid { display: flex; flex-direction: column; gap: 0.5rem; justify-content: center; }
	}
</style>

<script>
	(function () {
		function init(root: HTMLElement) {
			if (root.dataset.hmInit) return;
			root.dataset.hmInit = "1";
			if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
			root.classList.add("is-anim");
			// reveal the content once the curtain has begun clearing
			window.setTimeout(function () { root.classList.add("is-open"); }, 1700);
		}
		function boot() { document.querySelectorAll<HTMLElement>(".hm").forEach(init); }
		if (document.readyState !== "loading") boot();
		else document.addEventListener("DOMContentLoaded", boot);
	})();
</script>
