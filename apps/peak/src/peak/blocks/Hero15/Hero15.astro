---
import type { Hero15Props } from "./schema";
import PeakSection from "../PeakSection.astro";

const node = (Astro.props.node ?? {}) as Hero15Props;
const { image, imageAlt, phone, statValue, statLabel, ratingLabel, title, subtitle, agentPhoto, agentRole, agentName, thumbs } = node;
const thumbList = Array.isArray(thumbs) ? thumbs.filter((t) => t?.url) : [];
const stack = thumbList.slice(0, 3);
const secNode = { ...node, width: (node as any).width || "bleed" };
const rots = [5, 11, 18];
---

<PeakSection node={secNode} defaultWidth="bleed">
	<div class="he">
		{image && <img class="he__bg" src={image} alt={imageAlt ?? ""} loading="eager" />}
		<div class="he__overlay"></div>

		<!-- Card-stack intro: photos drop in one by one, each more rotated -->
		{stack.length > 0 && (
			<div class="he__intro" aria-hidden="true">
				<div class="he__stack">
					{stack.map((t, i) => (
						<img class="he__card" src={t.url} alt="" style={`--rot:${rots[i] ?? (i + 1) * 6}deg; animation-delay:${0.2 + i * 0.45}s`} />
					))}
				</div>
			</div>
		)}

		<div class="he__content">
			<div class="he__topbar">
				{phone && <div class="he__phone"><span>Call Me</span><strong>{phone}</strong></div>}
				{(statValue || statLabel) && <div class="he__stat"><strong>{statValue}</strong><span>{statLabel}</span></div>}
			</div>

			<div class="he__center">
				{ratingLabel && <div class="he__rating"><span class="he__stars">★★★★★</span><span>{ratingLabel}</span></div>}
				{title && <h1 class="he__title">{title}</h1>}
				{subtitle && <p class="he__subtitle">{subtitle}</p>}
			</div>

			<div class="he__bottom">
				{(agentName || agentPhoto) && (
					<div class="he__agent">
						{agentPhoto && <img class="he__agent-photo" src={agentPhoto} alt={agentName ?? ""} />}
						<div class="he__agent-info">
							{agentRole && <span class="he__agent-role">{agentRole}</span>}
							{agentName && <strong class="he__agent-name">{agentName}</strong>}
						</div>
					</div>
				)}
				{thumbList.length > 0 && (
					<div class="he__thumbs">
						{thumbList.map((t, i) => (
							<div class="he__thumb"><img src={t.url} alt="" /><span class="he__thumb-num">{i + 1} ·</span></div>
						))}
					</div>
				)}
			</div>
		</div>
	</div>
</PeakSection>

<style>
	.he { position: relative; min-height: clamp(560px, 96vh, 1000px); overflow: hidden; color: #fff; }
	.he__bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
	.he__overlay { position: absolute; inset: 0; background: rgba(40,46,52,0.32); }

	/* Intro */
	.he__intro { position: absolute; inset: 0; background: #fff; z-index: 5; display: flex; align-items: center; justify-content: center; animation: he-intro-out 0.7s ease 1.95s forwards; }
	.he__stack { position: relative; width: clamp(340px, 42vw, 580px); aspect-ratio: 4/3; }
	.he__card { position: absolute; top: 50%; left: 50%; width: 100%; height: 100%; object-fit: cover; border-radius: 14px; box-shadow: 0 24px 60px rgba(0,0,0,0.28); opacity: 0; transform: translate(-50%,-50%) scale(0.7) rotate(0deg); animation: he-card-in 0.6s cubic-bezier(0.34,1.3,0.5,1) both; }
	@keyframes he-card-in { to { opacity: 1; transform: translate(-50%,-50%) scale(1) rotate(var(--rot)); } }
	@keyframes he-intro-out { to { opacity: 0; visibility: hidden; } }

	/* Content reveals after the intro */
	.he__content { position: relative; max-width: var(--peak-wide, 1180px); margin: 0 auto; min-height: inherit; padding: clamp(1.5rem,3vw,2.5rem) var(--peak-gutter,1.5rem); display: flex; flex-direction: column; opacity: 0; animation: he-in 0.9s ease 2.4s both; }
	@keyframes he-in { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: none; } }
	@media (prefers-reduced-motion: reduce) { .he__intro { display: none; } .he__content { animation: none; opacity: 1; } }

	.he__topbar { display: flex; justify-content: space-between; gap: 2rem; font-size: 0.95rem; }
	.he__phone span, .he__stat span { display: block; opacity: 0.85; }
	.he__phone strong, .he__stat strong { font-size: 1.05rem; }
	.he__stat { text-align: right; } .he__stat strong { font-size: 1.6rem; }

	.he__center { margin: auto 0; text-align: center; }
	.he__rating { position: absolute; left: var(--peak-gutter,1.5rem); }
	.he__stars { display: block; letter-spacing: 2px; }
	.he__title { font-size: calc(clamp(2.5rem, 6vw, 5.5rem) * var(--peak-font-scale, 1)); font-weight: 500; margin: 0; line-height: 1; }
	.he__subtitle { font-size: calc(1.15rem * var(--peak-font-scale, 1)); margin: 1rem 0 0; opacity: 0.92; }

	.he__bottom { display: flex; align-items: flex-end; gap: 1rem; margin-top: auto; }
	.he__agent { display: flex; gap: 1rem; background: #fff; color: #1a1a1a; border-radius: 12px; padding: 12px; width: clamp(280px, 32%, 420px); flex: 0 0 auto; }
	.he__agent-photo { width: 96px; height: 110px; object-fit: cover; border-radius: 8px; }
	.he__agent-info { display: flex; flex-direction: column; justify-content: center; }
	.he__agent-role { color: #888; font-size: 0.9rem; }
	.he__agent-name { font-size: 1.3rem; margin-top: 0.5rem; }
	.he__thumbs { display: flex; gap: 0.5rem; flex: 1; overflow: hidden; }
	.he__thumb { position: relative; flex: 1; min-width: 0; aspect-ratio: 1; border-radius: 6px; overflow: hidden; }
	.he__thumb img { width: 100%; height: 100%; object-fit: cover; }
	.he__thumb-num { position: absolute; left: 8px; bottom: 6px; font-size: 0.85rem; font-weight: 600; }

	@media (max-width: 820px) { .he__bottom { flex-direction: column; align-items: stretch; } .he__thumbs { display: none; } }
</style>
