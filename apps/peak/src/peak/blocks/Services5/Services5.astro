---
import type { Services5Props } from "./schema";
import PeakSection from "../PeakSection.astro";

const node = (Astro.props.node ?? {}) as Services5Props;
const {
	title,
	intro,
	buttonText = "Read More",
	cards,
	accent = "#bdf739",
	cardColor = "#1f4030",
	panelColor = "#eeeeec",
} = node;

const cardList = Array.isArray(cards) ? cards.filter((c) => c?.title || c?.description) : [];
const arrow =
	'<path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M4 12h15m-6-6 6 6-6 6"/>';
// Faint decorative swoosh drawn into each light panel.
const swoosh =
	'<path fill="none" stroke="#fff" stroke-width="2" d="M-20 120C120 40 260 200 420 70S700 20 860 130"/><path fill="none" stroke="#fff" stroke-width="2" d="M-20 180C140 110 280 250 440 130S720 90 880 200"/>';
---

<PeakSection node={node}>
	<div class="ps5" style={`--accent:${accent}; --card:${cardColor}; --panel:${panelColor}`}>
		<header class="ps5__head">
			{title && <h2 class="ps5__title">{title}</h2>}
			{intro && <p class="ps5__intro">{intro}</p>}
		</header>

		{cardList.length > 0 && (
			<div class="ps5__grid">
				{cardList.map((c, i) => (
					<article class="ps5__cell">
						<svg class="ps5__swoosh" viewBox="0 0 860 260" preserveAspectRatio="xMidYMid slice" aria-hidden="true" set:html={swoosh} />
						<div class="ps5__cell-head">
							<span class="ps5__num">{String(i + 1).padStart(2, "0")}</span>
							{c.tagline && <span class="ps5__tag">{c.tagline}</span>}
						</div>
						<div class="ps5__inner">
							<div class="ps5__inner-head">
								{c.title && <h3 class="ps5__card-title">{c.title}</h3>}
								{c.badge && <span class="ps5__badge">{c.badge}</span>}
							</div>
							{c.description && <p class="ps5__desc">{c.description}</p>}
							{buttonText && (
								<a class="ps5__btn" href={c.url || undefined}>
									{buttonText}
									<svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" set:html={arrow} />
								</a>
							)}
						</div>
					</article>
				))}
			</div>
		)}
	</div>
</PeakSection>

<style>
	.ps5 { color: #15201a; }

	.ps5__head { max-width: 620px; margin-bottom: clamp(2rem, 4vw, 3.5rem); }
	.ps5__title {
		margin: 0;
		font-family: "Arial Narrow", "Helvetica Neue", sans-serif;
		font-stretch: condensed;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.01em;
		line-height: 0.95;
		font-size: calc(clamp(2.4rem, 5vw, 3.6rem) * var(--peak-font-scale, 1));
	}
	.ps5__intro {
		margin: 1.1rem 0 0;
		color: #6b6f6c;
		font-size: calc(1.05rem * var(--peak-font-scale, 1));
		line-height: 1.55;
	}

	.ps5__grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: clamp(1.25rem, 2.5vw, 2rem);
	}

	.ps5__cell {
		position: relative;
		overflow: hidden;
		background: var(--panel);
		border-radius: 20px;
		padding: clamp(1.5rem, 2.5vw, 2.5rem);
	}
	.ps5__swoosh {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		opacity: 0.6;
		mix-blend-mode: overlay;
		pointer-events: none;
	}
	.ps5__cell-head {
		position: relative;
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: clamp(1.25rem, 2.5vw, 2rem);
	}
	.ps5__num {
		font-family: "Arial Narrow", "Helvetica Neue", sans-serif;
		font-stretch: condensed;
		font-weight: 800;
		line-height: 1;
		color: var(--card);
		font-size: calc(clamp(2.6rem, 4vw, 3.6rem) * var(--peak-font-scale, 1));
	}
	.ps5__tag { margin-top: 0.4rem; color: #5e6360; font-size: 1rem; font-weight: 500; }

	.ps5__inner {
		position: relative;
		background: var(--card);
		border-radius: 16px;
		padding: clamp(1.5rem, 2.5vw, 2.25rem);
		color: #fff;
	}
	.ps5__inner-head { display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin-bottom: 1rem; }
	.ps5__card-title {
		margin: 0;
		font-family: "Arial Narrow", "Helvetica Neue", sans-serif;
		font-stretch: condensed;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.02em;
		font-size: calc(clamp(1.5rem, 2.2vw, 2rem) * var(--peak-font-scale, 1));
	}
	.ps5__badge {
		flex: 0 0 auto;
		background: rgba(255, 255, 255, 0.12);
		color: #d6e6db;
		padding: 0.4rem 0.95rem;
		border-radius: 999px;
		font-size: 0.85rem;
		font-weight: 500;
		white-space: nowrap;
	}
	.ps5__desc {
		margin: 0 0 1.75rem;
		color: #b4c5ba;
		font-size: calc(1rem * var(--peak-font-scale, 1));
		line-height: 1.55;
		max-width: 44ch;
	}
	.ps5__btn {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		padding: 0.85rem 1.5rem;
		border-radius: 999px;
		background: var(--accent);
		color: #15301d;
		font-weight: 700;
		font-size: 1rem;
		text-decoration: none;
	}

	@media (max-width: 860px) {
		.ps5__grid { grid-template-columns: 1fr; }
	}
</style>
