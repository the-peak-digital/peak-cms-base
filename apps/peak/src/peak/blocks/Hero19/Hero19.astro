---
import type { Hero19Props } from "./schema";
import PeakSection from "../PeakSection.astro";

const node = (Astro.props.node ?? {}) as Hero19Props;
const { videoUrl, poster, posterAlt, rating, ratingText, avatars, title, body, buttonText, buttonUrl } = node;
const avatarList = Array.isArray(avatars) ? avatars.filter((a) => a?.url).slice(0, 4) : [];
---

<PeakSection node={node} defaultWidth="bleed">
	<div class="mv">
		{videoUrl ? (
			<video class="mv__bg" autoplay muted loop playsinline poster={poster}>
				<source src={videoUrl} />
			</video>
		) : poster ? (
			<img class="mv__bg" src={poster} alt={posterAlt ?? ""} loading="eager" />
		) : null}

		<div class="mv__frost"></div>

		<div class="mv__content">
			<div class="mv__left">
				{(rating || avatarList.length > 0 || ratingText) && (
					<div class="mv__rating">
						{avatarList.length > 0 && (
							<span class="mv__avatars">{avatarList.map((a) => <img src={a.url} alt="" />)}</span>
						)}
						<span class="mv__rating-text">{rating} {ratingText}</span>
					</div>
				)}
				{title && <h1 class="mv__title">{title}</h1>}
			</div>

			<div class="mv__right">
				{body && <p class="mv__body">{body}</p>}
				{buttonText && <a class="mv__btn" href={buttonUrl}>{buttonText}</a>}
			</div>
		</div>
	</div>
</PeakSection>

<style>
	.mv { position: relative; overflow: hidden; border-radius: 28px; min-height: clamp(620px, 92vh, 1000px); color: #fff; }
	.mv__bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; display: block; }

	/* "Little frosted" — a subtle blur over the whole video plus a bottom scrim for legibility */
	.mv__frost { position: absolute; inset: 0; backdrop-filter: blur(3px); -webkit-backdrop-filter: blur(3px); background: linear-gradient(to top, rgba(18,28,22,0.62) 0%, rgba(18,28,22,0.18) 32%, rgba(255,255,255,0.05) 60%, rgba(255,255,255,0.08) 100%); }

	.mv__content { position: absolute; inset: auto 0 0 0; display: grid; grid-template-columns: 1.4fr 1fr; align-items: end; gap: 2rem; padding: clamp(1.75rem, 4vw, 3.5rem); }

	.mv__rating { display: inline-flex; align-items: center; gap: 0.85rem; align-self: flex-start; padding: 0.5rem 1.1rem 0.5rem 0.5rem; border-radius: 999px; background: rgba(255,255,255,0.16); backdrop-filter: blur(8px); border: 1px solid rgba(255,255,255,0.28); margin-bottom: 1.5rem; }
	.mv__avatars { display: flex; }
	.mv__avatars img { width: 34px; height: 34px; border-radius: 50%; object-fit: cover; border: 2px solid rgba(255,255,255,0.85); margin-left: -10px; }
	.mv__avatars img:first-child { margin-left: 0; }
	.mv__rating-text { font-size: 0.95rem; opacity: 0.95; }

	.mv__title { font-size: calc(clamp(2.4rem, 4.8vw, 4.25rem) * var(--peak-font-scale, 1)); font-weight: 700; line-height: 1.04; letter-spacing: -0.01em; margin: 0; text-shadow: 0 2px 18px rgba(0,0,0,0.25); }

	.mv__right { display: flex; flex-direction: column; align-items: flex-start; gap: 1.5rem; padding-bottom: 0.5rem; }
	.mv__body { font-size: calc(1.15rem * var(--peak-font-scale, 1)); line-height: 1.5; margin: 0; opacity: 0.95; }
	.mv__btn { padding: 0.95rem 1.9rem; border-radius: 12px; background: #f3f6ee; color: #2f5d34; font-weight: 600; text-decoration: none; }

	@media (max-width: 920px) {
		.mv__content { grid-template-columns: 1fr; gap: 1.5rem; }
	}
</style>
