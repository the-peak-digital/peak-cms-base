---
import type { Hero12Props } from "./schema";
import PeakSection from "../PeakSection.astro";

const node = (Astro.props.node ?? {}) as Hero12Props;
const { title, buttonText, buttonUrl, tagline, image, imageAlt, accent = "#f4e000" } = node;
const secNode = { ...node, width: (node as any).width || "bleed" };
---

<PeakSection node={secNode} defaultWidth="bleed">
	<div class="hbt">
		{image && <img class="hbt__bg" src={image} alt={imageAlt ?? ""} loading="eager" />}
		<div class="hbt__overlay"></div>
		<div class="hbt__inner">
			{title && <h1 class="hbt__title">{title}</h1>}
			<div class="hbt__bottom">
				{buttonText && (
					<a class="hbt__cta" href={buttonUrl}>
						<span>{buttonText}</span>
						<span class="hbt__arrow" style={`background:${accent}`} aria-hidden="true">→</span>
					</a>
				)}
				{tagline && <p class="hbt__tagline">{tagline}</p>}
			</div>
		</div>
	</div>
</PeakSection>

<style>
	.hbt { position: relative; min-height: clamp(560px, 92vh, 920px); overflow: hidden; color: #fff; }
	.hbt__bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
	.hbt__overlay { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(0,0,0,0.05) 0%, rgba(0,0,0,0) 40%, rgba(0,0,0,0.28) 100%); }
	.hbt__inner {
		position: relative; max-width: var(--peak-wide, 1180px); margin: 0 auto; min-height: inherit;
		padding: clamp(2.5rem, 5vw, 4.5rem) var(--peak-gutter, 1.5rem);
		display: flex; flex-direction: column; justify-content: flex-end; gap: 2.5rem;
	}
	.hbt__title { font-size: calc(clamp(2.75rem, 6vw, 5rem) * var(--peak-font-scale, 1)); font-weight: 600; line-height: 1.04; margin: 0; max-width: 14ch; }
	.hbt__bottom { display: flex; align-items: flex-end; justify-content: space-between; gap: 2rem; flex-wrap: wrap; }
	.hbt__cta {
		display: inline-flex; align-items: center; gap: 1.25rem;
		background: #fff; color: #1a1a1a; border-radius: 999px;
		padding: 0.5rem 0.5rem 0.5rem 1.75rem; font-weight: 600; font-size: 1.05rem; text-decoration: none;
	}
	.hbt__arrow { width: 48px; height: 48px; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #1a1a1a; font-size: 1.25rem; }
	.hbt__tagline { margin: 0; font-size: calc(1.15rem * var(--peak-font-scale, 1)); line-height: 1.35; max-width: 18ch; }

	@media (max-width: 640px) {
		.hbt__bottom { flex-direction: column; align-items: flex-start; }
	}
</style>
