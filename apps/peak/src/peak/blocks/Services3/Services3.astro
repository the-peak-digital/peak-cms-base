---
import type { Services3Props } from "./schema";
import PeakSection from "../PeakSection.astro";

const node = (Astro.props.node ?? {}) as Services3Props;
const {
	image,
	imageAlt,
	title,
	description,
	buttonText,
	buttonUrl = "#",
	accent = "#f7941e",
	cards,
} = node;

const cardList = Array.isArray(cards) ? cards.filter((c) => c?.title || c?.icon) : [];
const splitTags = (s?: string) =>
	(s ?? "")
		.split(/[,\n]/)
		.map((t) => t.trim())
		.filter(Boolean);

// Two-tone line icons: slate base (currentColor) + an orange accent path.
const icons: Record<string, string> = {
	megaphone:
		'<path fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" d="M4 10v4h3l8 4V6l-8 4H4z"/><path fill="none" stroke="#f7941e" stroke-width="1.6" stroke-linecap="round" d="M18 8.5c1.8 1.4 1.8 5.6 0 7M20.5 6.5c2.6 2 2.6 9 0 11"/>',
	buildings:
		'<path fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" d="M4 21V9h6v12M10 21V12h6v9M2 21h20"/><path fill="currentColor" d="M6 12h1.5v1.5H6zm0 3h1.5v1.5H6zm6 0h1.5v1.5H12zm0 3h1.5v1.5H12z"/><path fill="none" stroke="#f7941e" stroke-width="1.4" stroke-linecap="round" d="M16.5 6.5c1.1 0 2 .4 2.7 1.1M16.5 4c2 0 3.7.8 4.9 2.2"/>',
	iot:
		'<path fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" d="M12 4l7 4v8l-7 4-7-4V8z"/><circle cx="12" cy="12" r="2.6" fill="none" stroke="#f7941e" stroke-width="1.6"/><circle cx="12" cy="4" r="1.2" fill="currentColor"/><circle cx="19" cy="8" r="1.2" fill="currentColor"/><circle cx="19" cy="16" r="1.2" fill="currentColor"/><circle cx="12" cy="20" r="1.2" fill="currentColor"/><circle cx="5" cy="16" r="1.2" fill="currentColor"/><circle cx="5" cy="8" r="1.2" fill="currentColor"/>',
	headset:
		'<circle cx="12" cy="9" r="3" fill="none" stroke="currentColor" stroke-width="1.6"/><path fill="none" stroke="currentColor" stroke-width="1.6" d="M6.5 20a5.5 5.5 0 0 1 11 0M4 13v-2a8 8 0 0 1 16 0v2"/><path fill="#f7941e" d="M9 7.2a3 3 0 0 1 6 0z"/>',
	cloud:
		'<path fill="none" stroke="#f7941e" stroke-width="1.6" stroke-linejoin="round" d="M7.5 14a3.7 3.7 0 0 1 .5-7.4A4.8 4.8 0 0 1 17 8.2a3.3 3.3 0 0 1-.4 6.1z"/><path fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" d="M12 14v3M7 21l5-4 5 4M7 21v-2M17 21v-2"/>',
	web:
		'<rect x="3" y="4" width="18" height="13" rx="1.5" fill="none" stroke="currentColor" stroke-width="1.6"/><path fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" d="M9 21h6M12 17v4"/><circle cx="12" cy="10.5" r="2.6" fill="none" stroke="#f7941e" stroke-width="1.6"/>',
	code:
		'<path fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" d="m8 8-5 4 5 4m8-8 5 4-5 4"/><path stroke="#f7941e" stroke-width="1.6" stroke-linecap="round" d="m13 5-2 14"/>',
	mobile:
		'<rect x="6" y="3" width="12" height="18" rx="2.5" fill="none" stroke="currentColor" stroke-width="1.6"/><path stroke="#f7941e" stroke-width="1.6" stroke-linecap="round" d="M11 18h2"/>',
	server:
		'<rect x="4" y="4" width="16" height="6" rx="1.4" fill="none" stroke="currentColor" stroke-width="1.6"/><rect x="4" y="14" width="16" height="6" rx="1.4" fill="none" stroke="currentColor" stroke-width="1.6"/><circle cx="8" cy="7" r="1" fill="#f7941e"/><circle cx="8" cy="17" r="1" fill="#f7941e"/>',
	gear:
		'<circle cx="12" cy="12" r="3.2" fill="none" stroke="#f7941e" stroke-width="1.6"/><path fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" d="M12 3.5v2.5M12 18v2.5M3.5 12H6M18 12h2.5M6 6l1.8 1.8M16.2 16.2 18 18M18 6l-1.8 1.8M7.8 16.2 6 18"/>',
};
// Pastel tint cycled per card when no per-card tint is set (matches the design).
const palette = ["#dcebf7", "#eef1f3", "#eef1f3", "#fbe7d4", "#eef1f3", "#dff3f4"];
---

<PeakSection node={node}>
	<div class="ps3" style={`--accent:${accent}`}>
		<aside class="ps3__panel">
			{image && <img class="ps3__panel-img" src={image} alt={imageAlt ?? ""} loading="lazy" />}
			<div class="ps3__panel-body">
				{title && <h2 class="ps3__panel-title">{title}</h2>}
				{description && <p class="ps3__panel-text">{description}</p>}
				{buttonText && <a class="ps3__btn" href={buttonUrl}>{buttonText}</a>}
			</div>
		</aside>

		{cardList.length > 0 && (
			<div class="ps3__grid">
				{cardList.map((c, i) => (
					<article class="ps3__card" style={`--tint:${c.bg || palette[i % palette.length]}`}>
						<span class="ps3__icon">
							<svg viewBox="0 0 24 24" width="44" height="44" aria-hidden="true" set:html={icons[c.icon ?? "megaphone"] ?? icons.megaphone} />
						</span>
						{c.title && <h3 class="ps3__card-title">{c.title}</h3>}
						{splitTags(c.tags).length > 0 && (
							<ul class="ps3__tags">
								{splitTags(c.tags).map((t) => (
									<li class="ps3__tag">{t}</li>
								))}
							</ul>
						)}
					</article>
				))}
			</div>
		)}
	</div>
</PeakSection>

<style>
	.ps3 {
		display: grid;
		grid-template-columns: minmax(260px, 0.95fr) 2.1fr;
		gap: clamp(1rem, 2.5vw, 2rem);
		align-items: stretch;
	}

	/* Left promo panel. */
	.ps3__panel {
		position: relative;
		overflow: hidden;
		border-radius: 4px;
		min-height: 540px;
		display: flex;
		color: #fff;
		isolation: isolate;
	}
	.ps3__panel-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: -2; }
	.ps3__panel::before {
		content: "";
		position: absolute;
		inset: 0;
		z-index: -1;
		background: linear-gradient(180deg, rgba(40, 28, 38, 0.82), rgba(40, 28, 38, 0.72));
	}
	/* Right-pointing notch toward the grid. */
	.ps3__panel::after {
		content: "";
		position: absolute;
		top: 42%;
		right: -13px;
		border: 14px solid transparent;
		border-left-color: rgba(40, 28, 38, 0.78);
		border-right-width: 0;
	}
	.ps3__panel-body {
		margin: auto;
		padding: clamp(1.5rem, 4vw, 2.75rem);
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
	}
	.ps3__panel-title {
		font-size: calc(1.9rem * var(--peak-font-scale, 1));
		font-weight: 700;
		margin: 0 0 1.25rem;
	}
	.ps3__panel-text {
		font-size: calc(1.02rem * var(--peak-font-scale, 1));
		line-height: 1.6;
		margin: 0 0 1.75rem;
		max-width: 24ch;
	}
	.ps3__btn {
		padding: 0.95rem 1.9rem;
		border-radius: 6px;
		background: var(--accent);
		color: #fff;
		font-weight: 700;
		font-size: 1.02rem;
		text-decoration: none;
	}

	/* Right card grid. */
	.ps3__grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: clamp(0.75rem, 1.5vw, 1.25rem);
	}
	.ps3__card {
		background: var(--tint);
		border-radius: 8px;
		padding: clamp(1.25rem, 2vw, 1.9rem);
		color: #2b3a55;
	}
	.ps3__icon { display: block; color: #2b3a55; }
	.ps3__icon svg { display: block; }
	.ps3__card-title {
		font-size: calc(1.25rem * var(--peak-font-scale, 1));
		font-weight: 700;
		color: #3a4a63;
		margin: 1.5rem 0 1rem;
	}
	.ps3__tags { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; margin: 0; padding: 0; }
	.ps3__tag {
		background: #fff;
		border-radius: 4px;
		padding: 0.4rem 0.7rem;
		font-size: 0.85rem;
		font-weight: 600;
		color: #4a5568;
		box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
	}

	@media (max-width: 1080px) {
		.ps3 { grid-template-columns: 1fr; }
		.ps3__panel { min-height: 360px; }
		.ps3__panel::after { display: none; }
	}
	@media (max-width: 720px) {
		.ps3__grid { grid-template-columns: repeat(2, 1fr); }
	}
	@media (max-width: 480px) {
		.ps3__grid { grid-template-columns: 1fr; }
	}
</style>
