---
import type { Hero11Props } from "./schema";
import PeakSection from "../PeakSection.astro";

const node = (Astro.props.node ?? {}) as Hero11Props;
const { title, body, primaryText, primaryUrl, phone, infos, image, imageAlt, panelColor = "#f2924d" } = node;
const infoList = Array.isArray(infos) ? infos.filter((i) => i?.label || i?.value) : [];
const secNode = { ...node, width: (node as any).width || "full" };
const telHref = phone ? `tel:${phone.replace(/[^\d+]/g, "")}` : "#";
---

<PeakSection node={secNode} defaultWidth="full" background="#fdf3ea">
	<div class="hi">
		<div class="hi__left">
			{title && <h1 class="hi__title">{title}</h1>}
			{body && <p class="hi__body">{body}</p>}
			<div class="hi__actions">
				{primaryText && <a class="hi__btn" href={primaryUrl}>{primaryText}</a>}
				{phone && (
					<a class="hi__phone" href={telHref}><span class="hi__phone-icon">📞</span> : {phone}</a>
				)}
			</div>
			{infoList.length > 0 && (
				<div class="hi__infos">
					{infoList.map((i) => (
						<div class="hi__info">
							<span class="hi__info-icon">{i.icon || "•"}</span>
							<div>
								<span class="hi__info-label">{i.label}</span>
								<span class="hi__info-value">{i.value}</span>
							</div>
						</div>
					))}
				</div>
			)}
		</div>

		<div class="hi__panel" style={`background:${panelColor}`}>
			<span class="hi__rings" aria-hidden="true"></span>
			{image && <img class="hi__img" src={image} alt={imageAlt ?? ""} loading="eager" />}
		</div>
	</div>
</PeakSection>

<style>
	.hi { display: grid; grid-template-columns: 1fr 1fr; align-items: stretch; gap: clamp(2rem, 4vw, 4rem); min-height: clamp(520px, 70vh, 760px); }
	/* Left */
	.hi__left { display: flex; flex-direction: column; justify-content: center; padding: clamp(2rem, 4vw, 4rem) 0 clamp(2rem, 4vw, 4rem) var(--peak-gutter, 1.5rem); color: #1d1b3a; }
	.hi__title { font-size: calc(clamp(2.25rem, 4vw, 3.5rem) * var(--peak-font-scale, 1)); font-weight: 800; line-height: 1.12; margin: 0 0 1.5rem; }
	.hi__body { font-size: calc(1.1rem * var(--peak-font-scale, 1)); line-height: 1.6; color: #6b6a85; max-width: 32rem; margin: 0 0 2rem; }
	.hi__actions { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; margin-bottom: 2.5rem; }
	.hi__btn { background: #f2762a; color: #fff; padding: 1rem 1.75rem; border-radius: 10px; font-weight: 700; text-decoration: none; }
	.hi__phone { display: inline-flex; align-items: center; gap: 0.4rem; border: 1px solid #d9d4cc; border-radius: 999px; padding: 0.9rem 1.4rem; color: #1d1b3a; font-weight: 700; text-decoration: none; }
	.hi__infos { display: flex; flex-wrap: wrap; gap: 2.5rem; }
	.hi__info { display: flex; align-items: center; gap: 0.85rem; }
	.hi__info-icon { width: 48px; height: 48px; border-radius: 12px; background: #fbe1cf; display: flex; align-items: center; justify-content: center; font-size: 1.25rem; flex: 0 0 auto; }
	.hi__info-label { display: block; font-weight: 700; }
	.hi__info-value { display: block; color: #6b6a85; font-size: 0.95rem; }

	/* Right panel */
	.hi__panel { position: relative; overflow: hidden; border-radius: 18px; min-height: 360px; }
	.hi__rings { position: absolute; top: 8%; left: 50%; transform: translateX(-50%); width: 70%; aspect-ratio: 1; border-radius: 50%; border: 1.5px solid rgba(255,255,255,0.35); box-shadow: 0 0 0 40px rgba(255,255,255,0.0), inset 0 0 0 40px rgba(255,255,255,0.0); }
	.hi__rings::after { content: ""; position: absolute; inset: 14%; border-radius: 50%; border: 1.5px solid rgba(255,255,255,0.3); }
	.hi__img { position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); height: 92%; width: auto; max-width: 100%; object-fit: contain; object-position: bottom; }

	@media (max-width: 860px) {
		.hi { grid-template-columns: 1fr; }
		.hi__left { padding-inline: var(--peak-gutter, 1.5rem); }
		.hi__panel { min-height: 420px; margin: 0 var(--peak-gutter, 1.5rem); }
	}
</style>
