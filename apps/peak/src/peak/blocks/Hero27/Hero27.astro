---
import type { Hero27Props } from "./schema";
import PeakSection from "../PeakSection.astro";

const node = (Astro.props.node ?? {}) as Hero27Props;
const {
	title,
	titleAccent,
	image,
	imageAlt,
	formHeading,
	buttonText = "Submit",
	consentText,
	formAction,
} = node;
---

<PeakSection node={node} defaultWidth="bleed">
	<div class="hf">
		<div class="hf__head">
			<h1 class="hf__title">
				{title}
				{titleAccent && <span class="hf__title-accent"> {titleAccent}</span>}
			</h1>
		</div>

		<div class="hf__body">
			{image && <img class="hf__img" src={image} alt={imageAlt ?? ""} loading="eager" />}

			<form class="hf__form" method="POST" action={formAction || "#"}>
				{formHeading && <h2 class="hf__form-heading">{formHeading}</h2>}

				<div class="hf__row">
					<span class="hf__flag" aria-hidden="true">🇺🇸 US</span>
					<input class="hf__input hf__input--zip" name="zip" type="text" placeholder="ZIP Code" />
				</div>
				<input class="hf__input" name="first_name" type="text" placeholder="First Name" />
				<input class="hf__input" name="last_name" type="text" placeholder="Last Name" />
				<input class="hf__input" name="email" type="email" placeholder="Email" />
				<input class="hf__input" name="phone" type="tel" placeholder="Phone (mobile preferred)" />

				{
					consentText && (
						<label class="hf__consent">
							<input type="checkbox" name="consent" value="yes" />
							<span>{consentText}</span>
						</label>
					)
				}

				<button class="hf__submit" type="submit">
					<span>{buttonText}</span>
					<span class="hf__submit-arrow" aria-hidden="true">→</span>
				</button>
			</form>
		</div>
	</div>
</PeakSection>

<style>
	.hf {
		background: #fff;
		color: #111;
	}
	.hf__head {
		padding: clamp(2rem, 5vw, 4rem) clamp(1.5rem, 5vw, 4rem) clamp(1.5rem, 3vw, 2.5rem);
	}
	.hf__title {
		margin: 0;
		max-width: 22ch;
		font-size: calc(clamp(2.25rem, 5.5vw, 4.5rem) * var(--peak-font-scale, 1));
		font-weight: 600;
		line-height: 1.05;
		letter-spacing: -0.015em;
	}
	.hf__title-accent {
		color: #9a9a9a;
		font-weight: 400;
	}

	.hf__body {
		position: relative;
		min-height: clamp(520px, 64vw, 820px);
	}
	.hf__img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.hf__form {
		position: absolute;
		top: clamp(1.5rem, 3vw, 3rem);
		right: clamp(1rem, 4vw, 4rem);
		width: min(440px, 90%);
		background: #fff;
		border-radius: 4px;
		box-shadow: 0 24px 60px -22px rgba(0, 0, 0, 0.35);
		padding: clamp(1.75rem, 2.5vw, 2.5rem);
		display: flex;
		flex-direction: column;
		gap: 1.4rem;
		max-height: calc(100% - clamp(3rem, 6vw, 6rem));
		overflow: auto;
	}
	.hf__form-heading {
		margin: 0;
		font-size: calc(1.5rem * var(--peak-font-scale, 1));
		font-weight: 600;
		line-height: 1.2;
	}
	.hf__row {
		display: flex;
		align-items: center;
		gap: 1rem;
	}
	.hf__flag {
		white-space: nowrap;
		font-size: 0.95rem;
		color: #333;
	}
	.hf__input {
		flex: 1;
		min-width: 0;
		border: 0;
		border-bottom: 1px solid #d4d4d4;
		background: transparent;
		padding: 0.6rem 0;
		font-size: 1rem;
		color: #111;
	}
	.hf__input:focus {
		outline: none;
		border-bottom-color: #111;
	}
	.hf__consent {
		display: flex;
		gap: 0.7rem;
		font-size: 0.8rem;
		line-height: 1.45;
		color: #555;
	}
	.hf__consent input {
		margin-top: 0.2rem;
		flex: 0 0 auto;
		width: 18px;
		height: 18px;
	}
	.hf__submit {
		align-self: flex-start;
		display: inline-flex;
		align-items: center;
		gap: 1rem;
		background: #111;
		color: #fff;
		border: 0;
		border-radius: 999px;
		padding: 0.9rem 1.8rem;
		font-size: 1rem;
		font-weight: 600;
		cursor: pointer;
	}

	@media (max-width: 900px) {
		.hf__body {
			min-height: 0;
		}
		.hf__img {
			position: static;
			height: clamp(280px, 50vw, 460px);
		}
		.hf__form {
			position: static;
			width: 100%;
			max-height: none;
			box-shadow: none;
			padding: clamp(1.5rem, 6vw, 2rem) clamp(1.5rem, 5vw, 4rem);
		}
	}
</style>
