---
import type { Hero22Props } from "./schema";
import PeakSection from "../PeakSection.astro";

const node = (Astro.props.node ?? {}) as Hero22Props;
const {
	image, imageAlt, eyebrow, title, subtitle, primaryText, primaryUrl, secondaryText, secondaryUrl,
	videoImage, videoUrl, reviewerName, reviewerDate, reviewerAvatar, rating = 5, reviewText, reviewImage, reviewUrl,
} = node;
const stars = Math.max(0, Math.min(5, Math.round(Number(rating) || 0)));
const secNode = { ...node, width: (node as any).width || "full" };
---

<PeakSection node={secNode}>
	<div class="cs">
		{image && <img class="cs__bg" src={image} alt={imageAlt ?? ""} loading="eager" />}
		<div class="cs__shade"></div>

		<div class="cs__grid">
			<div class="cs__copy">
				{eyebrow && <p class="cs__eyebrow">{eyebrow}</p>}
				{title && <h1 class="cs__title">{title}</h1>}
				{subtitle && <p class="cs__subtitle">{subtitle}</p>}
				<div class="cs__actions">
					{primaryText && <a class="cs__btn" href={primaryUrl}>{primaryText}</a>}
					{secondaryText && <a class="cs__link" href={secondaryUrl}>{secondaryText}</a>}
				</div>
			</div>

			<aside class="cs__widget">
				{videoImage && (
					<a class="cs__video" href={videoUrl || "#"}>
						<img src={videoImage} alt="" loading="lazy" />
						<span class="cs__play" aria-hidden="true">
							<svg viewBox="0 0 24 24" width="20" height="20"><path fill="#1a1a1a" d="M8 5v14l11-7z"/></svg>
						</span>
					</a>
				)}

				<div class="cs__rev-head">
					<div class="cs__reviewer">
						{reviewerAvatar
							? <img class="cs__avatar" src={reviewerAvatar} alt={reviewerName ?? ""} />
							: <span class="cs__avatar cs__avatar--ph" aria-hidden="true">☺</span>}
						<span class="cs__reviewer-meta">
							{reviewerName && <strong>{reviewerName}</strong>}
							{reviewerDate && <span>{reviewerDate}</span>}
						</span>
					</div>
					<div class="cs__nav">
						<button type="button" aria-label="Previous"><svg viewBox="0 0 24 24" width="16" height="16"><path fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M15 6l-6 6 6 6"/></svg></button>
						<button type="button" aria-label="Next"><svg viewBox="0 0 24 24" width="16" height="16"><path fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M9 6l6 6-6 6"/></svg></button>
					</div>
				</div>

				<div class="cs__review">
					<div class="cs__review-top">
						<span class="cs__stars" aria-label={`${stars} out of 5`}>{"★".repeat(stars)}</span>
						<svg class="cs__verified" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path fill="#2f7df6" d="M12 2l2.4 1.8 3-.1 .9 2.9 2.5 1.6-.9 2.9.9 2.9-2.5 1.6-.9 2.9-3-.1L12 22l-2.4-1.8-3 .1-.9-2.9L3.2 16l.9-2.9-.9-2.9 2.5-1.6.9-2.9 3 .1L12 2z"/><path fill="#fff" d="M10.6 14.6l-2.3-2.3 1.1-1.1 1.2 1.2 3.3-3.3 1.1 1.1-4.4 4.4z"/></svg>
						<svg class="cs__g" viewBox="0 0 48 48" width="22" height="22" aria-hidden="true"><path fill="#FFC107" d="M43.6 20.5H42V20H24v8h11.3C33.7 32.9 29.3 36 24 36c-6.6 0-12-5.4-12-12s5.4-12 12-12c3.1 0 5.9 1.2 8 3.1l5.7-5.7C34.6 6.1 29.6 4 24 4 12.9 4 4 12.9 4 24s8.9 20 20 20 20-8.9 20-20c0-1.3-.1-2.3-.4-3.5z"/><path fill="#FF3D00" d="M6.3 14.7l6.6 4.8C14.7 16 19 12 24 12c3.1 0 5.9 1.2 8 3.1l5.7-5.7C34.6 6.1 29.6 4 24 4 16.3 4 9.7 8.3 6.3 14.7z"/><path fill="#4CAF50" d="M24 44c5.2 0 10-2 13.6-5.2l-6.3-5.3C29.2 35.1 26.7 36 24 36c-5.3 0-9.7-3.1-11.3-7.6l-6.5 5C9.6 39.6 16.2 44 24 44z"/><path fill="#1976D2" d="M43.6 20.5H42V20H24v8h11.3c-.8 2.2-2.2 4.1-4 5.5l6.3 5.3C41.4 36 44 30.6 44 24c0-1.3-.1-2.3-.4-3.5z"/></svg>
					</div>
					<div class="cs__review-body">
						{reviewText && <p>{reviewText}</p>}
						{reviewImage && <img class="cs__review-img" src={reviewImage} alt="" loading="lazy" />}
					</div>
					{reviewUrl && <a class="cs__readmore" href={reviewUrl}>Read more</a>}
				</div>
			</aside>
		</div>
	</div>
</PeakSection>

<style>
	.cs { position: relative; overflow: hidden; min-height: clamp(640px, 96vh, 1000px); color: #fff; }
	.cs__bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
	.cs__shade { position: absolute; inset: 0; background: linear-gradient(90deg, rgba(15,15,16,0.78) 0%, rgba(15,15,16,0.55) 45%, rgba(15,15,16,0.42) 100%); }

	.cs__grid { position: relative; display: grid; grid-template-columns: 1.5fr 1fr; align-items: center; gap: clamp(1.5rem, 4vw, 4rem); max-width: var(--peak-wide, 1180px); margin: 0 auto; padding: clamp(2rem, 5vw, 4rem) var(--peak-gutter, 1.5rem); min-height: inherit; }

	.cs__eyebrow { font-size: calc(1.25rem * var(--peak-font-scale, 1)); font-weight: 600; margin: 0 0 1.25rem; }
	.cs__title { font-size: calc(clamp(2.6rem, 5.5vw, 4.75rem) * var(--peak-font-scale, 1)); font-weight: 800; line-height: 1.04; letter-spacing: -0.01em; margin: 0; }
	.cs__subtitle { font-size: calc(1.4rem * var(--peak-font-scale, 1)); margin: 1.75rem 0 0; opacity: 0.95; }
	.cs__actions { display: flex; align-items: center; flex-wrap: wrap; gap: 1.5rem 2rem; margin-top: 2.5rem; }
	.cs__btn { padding: 1.05rem 2.5rem; border-radius: 999px; background: #fff; color: #1a1a1a; font-weight: 600; text-decoration: none; }
	.cs__link { color: #fff; font-weight: 600; text-decoration: none; }
	.cs__link:hover { text-decoration: underline; }

	.cs__widget { width: 100%; max-width: 30rem; margin-left: auto; }
	.cs__video { position: relative; display: block; border-radius: 16px; overflow: hidden; aspect-ratio: 16 / 10; }
	.cs__video img { width: 100%; height: 100%; object-fit: cover; }
	.cs__play { position: absolute; inset: 0; margin: auto; width: 54px; height: 54px; border-radius: 50%; background: rgba(255,255,255,0.9); display: flex; align-items: center; justify-content: center; }

	.cs__rev-head { display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin: 1.1rem 0; }
	.cs__reviewer { display: flex; align-items: center; gap: 0.75rem; }
	.cs__avatar { width: 42px; height: 42px; border-radius: 50%; object-fit: cover; }
	.cs__avatar--ph { display: inline-flex; align-items: center; justify-content: center; background: #000; color: #fff; font-size: 1.2rem; }
	.cs__reviewer-meta { display: flex; flex-direction: column; line-height: 1.25; }
	.cs__reviewer-meta span { opacity: 0.7; font-size: 0.9rem; }
	.cs__nav { display: flex; gap: 0.6rem; }
	.cs__nav button { width: 38px; height: 38px; border-radius: 50%; border: 1px solid rgba(255,255,255,0.4); background: transparent; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; }

	.cs__review { position: relative; background: #1c1d20; border-radius: 16px; padding: 1.25rem 1.4rem; }
	.cs__review::before { content: ""; position: absolute; top: -8px; left: 22px; border: 8px solid transparent; border-top: 0; border-bottom-color: #1c1d20; }
	.cs__review-top { display: flex; align-items: center; gap: 0.5rem; }
	.cs__stars { color: #f5b400; letter-spacing: 1px; }
	.cs__g { margin-left: auto; }
	.cs__review-body { display: flex; gap: 1rem; margin-top: 0.9rem; }
	.cs__review-body p { margin: 0; font-size: 0.98rem; line-height: 1.4; color: #e6e7ea; }
	.cs__review-img { width: 84px; height: 84px; border-radius: 10px; object-fit: cover; flex: 0 0 auto; align-self: flex-start; }
	.cs__readmore { display: inline-block; margin-top: 1rem; color: #b9bcc2; font-size: 0.95rem; text-decoration: none; }

	@media (max-width: 920px) {
		.cs__grid { grid-template-columns: 1fr; }
		.cs__widget { margin: 1rem 0 0; }
	}
</style>
