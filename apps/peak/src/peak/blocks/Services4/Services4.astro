---
import type { Services4Props } from "./schema";
import PeakSection from "../PeakSection.astro";

const node = (Astro.props.node ?? {}) as Services4Props;
const { title, intro, buttonText, buttonUrl = "#", services, accent = "#ff5419", bg = "#141414" } = node;

const list = (Array.isArray(services) ? services : []).filter((s) => s?.title || s?.image);
// Keep original index (= image index) while splitting into the two flanking
// columns: evens on the left (0,2,…), odds on the right (1,3,…).
const indexed = list.map((s, i) => ({ ...s, i }));
const leftItems = indexed.filter((s) => s.i % 2 === 0);
const rightItems = indexed.filter((s) => s.i % 2 === 1);
---

<PeakSection node={node}>
	<div class="ps4" style={`--accent:${accent}; --bg:${bg}`} data-services-count={list.length}>
		<header class="ps4__head">
			{title && <h2 class="ps4__title">{title}</h2>}
			{intro && <p class="ps4__intro">{intro}</p>}
		</header>

		<div class="ps4__stage">
			<div class="ps4__col ps4__col--left">
				{leftItems.map((s) => (
					<div class:list={["ps4__item", { "is-active": s.i === 0 }]} data-index={s.i} tabindex="0">
						{s.title && <h3 class="ps4__item-title">{s.title}</h3>}
						{s.description && <p class="ps4__item-text">{s.description}</p>}
						{buttonText && <a class="ps4__cta" href={buttonUrl}>{buttonText}</a>}
					</div>
				))}
			</div>

			<div class="ps4__media">
				{list.map((s, i) => (
					<img class:list={["ps4__img", { "is-shown": i === 0 }]} data-img={i} src={s.image} alt={s.imageAlt ?? s.title ?? ""} loading="lazy" />
				))}
			</div>

			<div class="ps4__col ps4__col--right">
				{rightItems.map((s) => (
					<div class:list={["ps4__item", "ps4__item--right", { "is-active": s.i === 0 }]} data-index={s.i} tabindex="0">
						{s.title && <h3 class="ps4__item-title">{s.title}</h3>}
						{s.description && <p class="ps4__item-text">{s.description}</p>}
						{buttonText && <a class="ps4__cta" href={buttonUrl}>{buttonText}</a>}
					</div>
				))}
			</div>
		</div>
	</div>
</PeakSection>

<style>
	.ps4 {
		background: var(--bg);
		color: #fff;
		border-radius: 6px;
		padding: clamp(2rem, 4vw, 3.5rem) clamp(1.5rem, 3vw, 3rem) clamp(3rem, 5vw, 4.5rem);
	}

	.ps4__head {
		display: grid;
		grid-template-columns: 1fr 1.15fr 1fr;
		gap: clamp(1rem, 3vw, 2.5rem);
		align-items: start;
		margin-bottom: clamp(1.5rem, 3vw, 2.5rem);
	}
	.ps4__title {
		grid-column: 1;
		margin: 0;
		font-family: "Arial Narrow", "Helvetica Neue", sans-serif;
		font-stretch: condensed;
		font-weight: 800;
		letter-spacing: -0.01em;
		line-height: 0.9;
		font-size: calc(clamp(3.5rem, 8vw, 7rem) * var(--peak-font-scale, 1));
	}
	.ps4__intro {
		grid-column: 2;
		margin: 0.5rem 0 0;
		color: #9a9a9a;
		font-size: calc(1.05rem * var(--peak-font-scale, 1));
		line-height: 1.5;
	}

	/* Three columns: flanking items + central image. */
	.ps4__stage {
		display: grid;
		grid-template-columns: 1fr 1.15fr 1fr;
		gap: clamp(1rem, 3vw, 2.5rem);
		align-items: stretch;
	}
	.ps4__col {
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		gap: 2rem;
		min-height: clamp(420px, 60vh, 660px);
	}
	.ps4__col--right { text-align: right; }

	.ps4__item {
		cursor: pointer;
		outline: none;
	}
	.ps4__item-title {
		margin: 0 0 0.9rem;
		font-family: "Arial Narrow", "Helvetica Neue", sans-serif;
		font-stretch: condensed;
		font-weight: 800;
		letter-spacing: 0.01em;
		font-size: calc(clamp(1.6rem, 2.3vw, 2.3rem) * var(--peak-font-scale, 1));
		color: #565656;
		transition: color 0.35s ease;
	}
	.ps4__item-text {
		margin: 0;
		font-size: calc(1rem * var(--peak-font-scale, 1));
		line-height: 1.5;
		color: #6f6f6f;
		max-width: 42ch;
		transition: color 0.35s ease;
	}
	.ps4__col--right .ps4__item-text { margin-left: auto; }
	/* Spotlight the active item. */
	.ps4__item.is-active .ps4__item-title { color: #fff; }
	.ps4__item.is-active .ps4__item-text { color: #c9c9c9; }
	.ps4__cta {
		display: none;
		margin-top: 1.5rem;
		padding: 0.85rem 1.6rem;
		border-radius: 3px;
		background: var(--accent);
		color: #fff;
		font-weight: 600;
		font-size: 1rem;
		text-decoration: none;
	}
	.ps4__item.is-active .ps4__cta { display: inline-block; }

	/* Central image with crossfade. */
	.ps4__media {
		position: relative;
		min-height: clamp(420px, 60vh, 660px);
		background: #0c0c0c;
	}
	.ps4__img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		opacity: 0;
		transition: opacity 0.55s ease;
	}
	.ps4__img.is-shown { opacity: 1; }

	@media (prefers-reduced-motion: reduce) {
		.ps4__img, .ps4__item-title, .ps4__item-text { transition: none; }
	}

	@media (max-width: 960px) {
		.ps4__head { grid-template-columns: 1fr; }
		.ps4__intro { grid-column: 1; }
		.ps4__stage { grid-template-columns: 1fr; }
		.ps4__col { min-height: 0; }
		.ps4__col--right, .ps4__col--right .ps4__item-text { text-align: left; margin-left: 0; }
		.ps4__media { order: -1; min-height: 320px; }
	}
</style>

<script>
	// Hover/focus spotlight: activate the item and crossfade to its image.
	// Per-instance guard + astro:page-load re-init (works after client nav).
	function initPs4(root: HTMLElement) {
		if (root.dataset.ps4Init) return;
		root.dataset.ps4Init = "1";
		const items = Array.from(root.querySelectorAll<HTMLElement>(".ps4__item"));
		const imgs = Array.from(root.querySelectorAll<HTMLElement>(".ps4__img"));
		const activate = (idx: number) => {
			items.forEach((it) => it.classList.toggle("is-active", Number(it.dataset.index) === idx));
			imgs.forEach((im) => im.classList.toggle("is-shown", Number(im.dataset.img) === idx));
		};
		items.forEach((it) => {
			const idx = Number(it.dataset.index);
			it.addEventListener("mouseenter", () => activate(idx));
			it.addEventListener("focusin", () => activate(idx));
		});
	}
	function initAllPs4() {
		document.querySelectorAll<HTMLElement>(".ps4").forEach(initPs4);
	}
	document.addEventListener("astro:page-load", initAllPs4);
	initAllPs4();
</script>
