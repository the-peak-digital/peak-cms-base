---
/**
 * PeakSection — the shared root every block renders. It centralizes the two
 * per-block settings that live in defineBlock's common fields:
 *
 *   - width    : "contained" (default) | "full-bg" | "full"
 *   - fontSize : applied as the --peak-font-scale CSS variable
 *
 * Because blocks are rendered by Emdash's PortableText (which passes `node`
 * directly, with no outer wrapper), applying these here — at the block root —
 * makes them work on real pages, not just the demo renderer.
 *
 * Width modes (self-contained, no parent grid needed — uses the full-bleed
 * margin trick so it works wherever the block is dropped):
 *   contained -> inner content constrained to --peak-wide (lines up with page)
 *   full-bg   -> element spans the viewport (background edge-to-edge), inner
 *                content still constrained to --peak-wide
 *   full      -> element AND content span the viewport edge-to-edge
 *
 * Pass `background` for full-bg colored bands; it sits on the full-width element.
 */
import { FONT_SIZE_SCALE, CONTENT_WIDTH_VALUES } from "./defineBlock";

interface Props {
	node?: { width?: string; fontSize?: string; contentWidth?: string };
	/** Extra class on the inner content element. */
	class?: string;
	/** Background applied to the (possibly full-width) outer element. */
	background?: string;
}

const { node = {}, class: innerClass, background } = Astro.props;
// Sections default to full width (full-bleed element + content). Editors can
// switch a block back to "Normal" (contained) or "Full background" per-block.
const width = node.width ?? "full-bg";
const scale = FONT_SIZE_SCALE[node.fontSize ?? "md"] ?? 1;
// Per-section content width: override the global --peak-wide for this block only.
const cw = CONTENT_WIDTH_VALUES[node.contentWidth ?? "default"];

// Background goes on whichever layer is the visible "band":
//   contained -> the inner column (bg behind content only)
//   full-bg / full -> the full-width outer element (bg edge-to-edge)
const bgOnOuter = width === "full-bg" || width === "full";
const outerStyle = [
	`--peak-font-scale:${scale}`,
	bgOnOuter && background ? `background:${background}` : "",
]
	.filter(Boolean)
	.join(";");
const innerStyle =
	[!bgOnOuter && background ? `background:${background}` : "", cw ? `--peak-wide:${cw}` : ""]
		.filter(Boolean)
		.join(";") || undefined;
---

<div class:list={["peak-sec", `peak-sec--${width}`]} style={outerStyle}>
	<div class:list={["peak-sec__inner", innerClass]} style={innerStyle}>
		<slot />
	</div>
</div>

<style is:global>
	/* contained: normal flow; inner constrained to the page column */
	.peak-sec--contained > .peak-sec__inner,
	.peak-sec--full-bg > .peak-sec__inner {
		max-width: var(--peak-wide, 1180px);
		margin-inline: auto;
		padding-inline: var(--peak-gutter, 1.5rem);
		box-sizing: border-box;
	}
	/* full-bg + full: break out to the full viewport width */
	.peak-sec--full-bg,
	.peak-sec--full {
		width: 100vw;
		margin-inline: calc(50% - 50vw);
	}
	/* full: content spans truly edge-to-edge — no side gutter. Blocks provide
	   their own inner padding, so sections fill the viewport with no margins. */
	.peak-sec--full > .peak-sec__inner {
		padding-inline: 0;
		box-sizing: border-box;
	}
</style>
