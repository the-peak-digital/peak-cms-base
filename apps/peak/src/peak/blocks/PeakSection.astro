---
/**
 * PeakSection — the shared root every block renders. It centralizes the two
 * per-block settings that live in defineBlock's common fields:
 *
 *   - width    : "contained" (default) | "full-bg" | "full"
 *   - fontSize : applied as the --peak-font-scale CSS variable
 *
 * Because blocks are rendered by Emdash's PortableText (which passes `node`
 * directly, with no outer wrapper), applying these here — at the block root —
 * makes them work on real pages, not just the demo renderer.
 *
 * Width modes (self-contained, no parent grid needed — uses the full-bleed
 * margin trick so it works wherever the block is dropped):
 *   contained -> inner content constrained to --peak-wide (lines up with page)
 *   full-bg   -> element spans the viewport (background edge-to-edge), inner
 *                content still constrained to --peak-wide
 *   full      -> element AND content span the viewport edge-to-edge
 *
 * Pass `background` for full-bg colored bands; it sits on the full-width element.
 */
import { FONT_SIZE_SCALE } from "./defineBlock";

interface Props {
	node?: { width?: string; fontSize?: string; contentWidth?: string };
	/** Extra class on the inner content element. */
	class?: string;
	/** Background applied to the (possibly full-width) outer element. */
	background?: string;
	/**
	 * The block's own intended width when the editor hasn't chosen one. Each block
	 * declares this based on its design — there's no single global answer:
	 *   "full"     -> full-bleed, the block owns its layout edge-to-edge
	 *                 (split heroes, image walls, scroll galleries)
	 *   "full-bg"  -> full-width band, content aligned to --peak-wide (default;
	 *                 most content sections)
	 *   "contained"-> boxed to --peak-wide
	 * Editors can still override per-section via the Width field.
	 */
	defaultWidth?: "contained" | "full-bg" | "full" | "bleed";
}

const { node = {}, class: innerClass, background, defaultWidth = "full-bg" } = Astro.props;
// Width is LOCKED to the block's design (defaultWidth set in code) — it is not an
// editor field, so it can't be misconfigured. Any legacy node.width saved in old
// content is intentionally ignored so existing pages snap to the correct width.
const width = defaultWidth;
const scale = FONT_SIZE_SCALE[node.fontSize ?? "md"] ?? 1;
// Content width is GLOBAL: every section aligns to --peak-wide (set once in
// BaseLayout). No per-section override — content edges line up site-wide.

// Background goes on whichever layer is the visible "band":
//   contained -> the inner column (bg behind content only)
//   full-bg / full -> the full-width outer element (bg edge-to-edge)
const bgOnOuter = width === "full-bg" || width === "full" || width === "bleed";
const outerStyle = [
	`--peak-font-scale:${scale}`,
	bgOnOuter && background ? `background:${background}` : "",
]
	.filter(Boolean)
	.join(";");
const innerStyle = !bgOnOuter && background ? `background:${background}` : undefined;
---

<div class:list={["peak-sec", `peak-sec--${width}`]} style={outerStyle}>
	<div class:list={["peak-sec__inner", innerClass]} style={innerStyle}>
		<slot />
	</div>
</div>

<style is:global>
	/* contained: normal flow; inner constrained to the page column */
	.peak-sec--contained > .peak-sec__inner,
	.peak-sec--full-bg > .peak-sec__inner {
		max-width: var(--peak-wide, 1180px);
		margin-inline: auto;
		padding-inline: var(--peak-gutter, 1.5rem);
		box-sizing: border-box;
	}
	/* full-bg + full + bleed: break out to the full viewport width */
	.peak-sec--full-bg,
	.peak-sec--full,
	.peak-sec--bleed {
		width: 100vw;
		margin-inline: calc(50% - 50vw);
	}
	/* full: content fills the viewport but keeps a small safe gutter so text
	   never touches the screen edge. Truly full-bleed blocks (images, scroll
	   galleries) do their own 100vw breakout, which cancels this gutter. */
	.peak-sec--full > .peak-sec__inner {
		padding-inline: var(--peak-gutter, 1.5rem);
		box-sizing: border-box;
	}
	/* bleed: element AND content edge-to-edge, ZERO gutter — for full-cover
	   image/media blocks whose own inner element handles text padding. */
	.peak-sec--bleed > .peak-sec__inner {
		padding-inline: 0;
		box-sizing: border-box;
	}
</style>
