---
import type { Hero20Props } from "./schema";
import PeakSection from "../PeakSection.astro";

const node = (Astro.props.node ?? {}) as Hero20Props;
const {
	badge, title, body, primaryText, primaryUrl, secondaryText, secondaryUrl,
	rating = 5, ratingText, image1, image1Alt, image2, image2Alt,
	clientsAvatars, clientsText, accent = "#1f3d2b",
} = node;
const stars = Math.max(0, Math.min(5, Math.round(Number(rating) || 0)));
const avatarList = Array.isArray(clientsAvatars) ? clientsAvatars.filter((a) => a?.url).slice(0, 5) : [];
---

<PeakSection node={node} defaultWidth="full">
	<div class="ed" style={`--accent:${accent}`}>
		<div class="ed__left">
			{badge && (
				<span class="ed__badge">
					<svg class="ed__badge-ico" viewBox="0 0 24 24" width="15" height="15" aria-hidden="true"><path fill="currentColor" d="m12 1.5 2.3 1.7 2.85-.13 1 2.68 2.42 1.5-.86 2.74.86 2.74-2.42 1.5-1 2.68L14.3 18.8 12 20.5l-2.3-1.7-2.85.13-1-2.68-2.42-1.5.86-2.74-.86-2.74 2.42-1.5 1-2.68 2.85.13L12 1.5Z"/><path fill="#fff" d="m10.6 14.3-2.5-2.5 1.1-1.1 1.4 1.4 3.2-3.2 1.1 1.1-4.3 4.3Z"/></svg>
					{badge}
				</span>
			)}
			{title && <h1 class="ed__title">{title}</h1>}
			{body && <p class="ed__body">{body}</p>}

			<div class="ed__actions">
				{primaryText && (
					<a class="ed__btn ed__btn--primary" href={primaryUrl}>{primaryText}
						<svg viewBox="0 0 24 24" width="17" height="17" aria-hidden="true"><path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M7 17 17 7M9 7h8v8"/></svg>
					</a>
				)}
				{secondaryText && (
					<a class="ed__btn ed__btn--soft" href={secondaryUrl}>{secondaryText}
						<svg viewBox="0 0 24 24" width="17" height="17" aria-hidden="true"><path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 6l6 6-6 6"/></svg>
					</a>
				)}
			</div>

			<hr class="ed__rule" />
			{(stars > 0 || ratingText) && (
				<div class="ed__rating">
					<span class="ed__stars" aria-label={`${stars} out of 5`}>{"★".repeat(stars)}</span>
					<span class="ed__rating-sep">|</span>
					<span class="ed__rating-text">{ratingText}</span>
				</div>
			)}
		</div>

		<div class="ed__right">
			<div class="ed__cards">
				{image1 && <img class="ed__card" src={image1} alt={image1Alt ?? ""} loading="eager" />}
				{image2 && <img class="ed__card" src={image2} alt={image2Alt ?? ""} loading="eager" />}
			</div>
			{(avatarList.length > 0 || clientsText) && (
				<>
					<hr class="ed__rule" />
					<div class="ed__social">
						{avatarList.length > 0 && (
							<span class="ed__avatars">{avatarList.map((a) => <img src={a.url} alt="" />)}</span>
						)}
						{clientsText && <span class="ed__social-text">{clientsText}</span>}
					</div>
				</>
			)}
		</div>
	</div>
</PeakSection>

<style>
	.ed { display: grid; grid-template-columns: 1fr 1.1fr; gap: clamp(2rem, 5vw, 5rem); align-items: center; padding-block: clamp(1.5rem, 4vw, 3rem); }
	.ed__left { display: flex; flex-direction: column; align-items: flex-start; }

	.ed__badge { display: inline-flex; align-items: center; gap: 0.55rem; padding: 0.5rem 1.1rem; border-radius: 999px; border: 1px solid #d8dcd2; font-size: 0.85rem; font-weight: 600; letter-spacing: 0.06em; color: #2a2f29; }
	.ed__badge-ico { color: var(--accent); flex: 0 0 auto; }
	.ed__btn svg { flex: 0 0 auto; }
	.ed__title { font-family: Georgia, "Times New Roman", serif; font-size: calc(clamp(2.6rem, 5vw, 4.5rem) * var(--peak-font-scale, 1)); font-weight: 500; line-height: 1.06; letter-spacing: -0.01em; color: #14180f; margin: 1.75rem 0 0; }
	.ed__body { font-size: calc(1.2rem * var(--peak-font-scale, 1)); line-height: 1.5; color: #565b51; margin: 1.5rem 0 0; max-width: 30rem; }

	.ed__actions { display: flex; flex-wrap: wrap; gap: 1rem; margin-top: 2rem; }
	.ed__btn { display: inline-flex; align-items: center; gap: 0.6rem; padding: 1.05rem 1.9rem; border-radius: 12px; font-weight: 600; text-decoration: none; }
	.ed__btn--primary { background: var(--accent); color: #fff; }
	.ed__btn--soft { background: #dde7cf; color: #1f3d2b; }

	.ed__rule { width: 100%; border: 0; border-top: 1px solid #e2e4dc; margin: 2rem 0; }
	.ed__rating { display: flex; align-items: center; gap: 0.9rem; }
	.ed__stars { color: var(--accent); letter-spacing: 3px; font-size: 1.05rem; }
	.ed__rating-sep { color: #c3c7bd; }
	.ed__rating-text { color: #2a2f29; }

	.ed__right { display: flex; flex-direction: column; }
	.ed__cards { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
	.ed__card { width: 100%; aspect-ratio: 3 / 4; object-fit: cover; border-radius: 18px; display: block; }
	.ed__social { display: flex; align-items: center; justify-content: flex-end; gap: 1rem; }
	.ed__avatars { display: flex; }
	.ed__avatars img { width: 40px; height: 40px; border-radius: 50%; object-fit: cover; border: 2px solid #fff; margin-left: -12px; }
	.ed__avatars img:first-child { margin-left: 0; }
	.ed__social-text { font-size: 1.1rem; color: #2a2f29; }

	@media (max-width: 900px) {
		.ed { grid-template-columns: 1fr; }
		.ed__right { margin-top: 1rem; }
		.ed__social { justify-content: flex-start; }
	}
</style>
