---
import type { Services16Props } from "./schema";
import PeakSection from "../PeakSection.astro";

const node = (Astro.props.node ?? {}) as Services16Props;
const { badge, title, tagline, cards, accent = "#4f46e5", cardColor = "#eef0fb" } = node;

const COLS = 3;
const list = (Array.isArray(cards) ? cards : []).filter((c) => c?.title || c?.image);
const rows = Math.max(1, Math.ceil(list.length / COLS));

// Entrance delay grows with distance from the grid centre, so the middle card
// loads first and the rest follow outward.
const delayFor = (i: number) => {
	const col = i % COLS;
	const row = Math.floor(i / COLS);
	const dist = Math.abs(col - (COLS - 1) / 2) + Math.abs(row - (rows - 1) / 2);
	return (dist * 0.1).toFixed(2);
};

const icons: Record<string, string> = {
	planning: '<path fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" d="M4 4v16h16M8 16l4-6 4 3"/>',
	box: '<path fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" d="M12 3l8 4.5v9L12 21l-8-4.5v-9zM4 7.5l8 4.5 8-4.5M12 12v9"/>',
	binoculars: '<path fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" d="M7 5h3l1 4M17 5h-3l-1 4M5 14a3 3 0 1 0 6 0l-1-5H6zM19 14a3 3 0 1 1-6 0l1-5h4zM11 11h2"/>',
	bolt: '<path fill="currentColor" d="M13 2 4 14h6l-1 8 9-12h-6z"/>',
	bulb: '<path fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" d="M9 18h6M10 21h4M12 3a6 6 0 0 1 4 10.5c-.6.6-1 1.3-1 2.1H9c0-.8-.4-1.5-1-2.1A6 6 0 0 1 12 3z"/>',
	home: '<path fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" d="M3 11l9-7 9 7M5 10v10h14V10"/>',
	shield: '<path fill="currentColor" d="M12 2 4 5v6c0 5 3.4 8.5 8 11 4.6-2.5 8-6 8-11V5z"/>',
	gear: '<circle cx="12" cy="12" r="3.2" fill="none" stroke="currentColor" stroke-width="1.8"/><path fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" d="M12 3.5v2.5M12 18v2.5M3.5 12H6M18 12h2.5M6 6l1.8 1.8M16.2 16.2 18 18M18 6l-1.8 1.8M7.8 16.2 6 18"/>',
};
---

<PeakSection node={node}>
	<div class="ps16" style={`--accent:${accent}; --card:${cardColor}`}>
		<header class="ps16__head">
			<div class="ps16__head-left">
				{badge && <span class="ps16__badge">{badge}</span>}
				{title && <h2 class="ps16__title">{title}</h2>}
			</div>
			{tagline && <p class="ps16__tagline">{tagline}</p>}
		</header>

		{list.length > 0 && (
			<div class="ps16__grid">
				{list.map((c, i) =>
					c.kind === "image" ? (
						<div class="ps16__card ps16__card--image" style={`--d:${delayFor(i)}s`}>
							{c.image && <img src={c.image} alt={c.alt ?? c.title ?? ""} loading="lazy" />}
						</div>
					) : (
						<article class="ps16__card ps16__card--text" style={`--d:${delayFor(i)}s`}>
							<span class="ps16__icon">
								<svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true" set:html={icons[c.icon ?? "planning"] ?? icons.planning} />
							</span>
							{c.title && <h3 class="ps16__card-title">{c.title}</h3>}
							{c.description && <p class="ps16__card-text">{c.description}</p>}
						</article>
					),
				)}
			</div>
		)}
	</div>
</PeakSection>

<style>
	.ps16 { color: #15161a; }

	.ps16__head { display: grid; grid-template-columns: 1.7fr 1fr; gap: 2rem; align-items: start; margin-bottom: clamp(2rem, 4vw, 3.5rem); }
	.ps16__badge { display: inline-block; padding: 0.4rem 0.9rem; background: #edeef2; border-radius: 999px; font-size: 0.95rem; font-weight: 500; color: #555; }
	.ps16__title {
		margin: 1.25rem 0 0;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: -0.02em;
		line-height: 0.95;
		font-size: calc(clamp(2.6rem, 6vw, 5rem) * var(--peak-font-scale, 1));
	}
	.ps16__tagline { margin-top: 0.5rem; color: #6b6862; font-size: calc(1.05rem * var(--peak-font-scale, 1)); line-height: 1.5; }

	.ps16__grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: clamp(1rem, 1.6vw, 1.5rem);
		grid-auto-rows: clamp(300px, 26vw, 380px);
	}
	.ps16__card { border-radius: 18px; overflow: hidden; }
	.ps16__card--image { background: #e4e0da; }
	.ps16__card--image img { width: 100%; height: 100%; object-fit: cover; }
	.ps16__card--text {
		background: var(--card);
		padding: clamp(1.5rem, 2.2vw, 2.25rem);
		display: flex;
		flex-direction: column;
	}
	.ps16__icon {
		display: grid;
		place-items: center;
		width: 52px;
		height: 52px;
		border-radius: 50%;
		background: var(--accent);
		color: #fff;
	}
	.ps16__card-title {
		margin: auto 0 0;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.01em;
		font-size: calc(clamp(1.2rem, 1.7vw, 1.5rem) * var(--peak-font-scale, 1));
	}
	.ps16__card-text { margin: 0.9rem 0 0; color: #6b6f78; font-size: calc(1.02rem * var(--peak-font-scale, 1)); line-height: 1.5; }

	/* Load-from-the-middle entrance. Keyframe (not a 2-state transition) so it
	   plays reliably; gated behind .is-anim (JS only). */
	@keyframes ps16-in {
		from { opacity: 0; transform: scale(0.92) translateY(14px); }
		to { opacity: 1; transform: none; }
	}
	.ps16.is-anim .ps16__card { opacity: 0; }
	.ps16.is-anim.is-in .ps16__card { animation: ps16-in 0.6s cubic-bezier(0.22, 1, 0.36, 1) var(--d, 0s) both; }
	@media (prefers-reduced-motion: reduce) {
		.ps16.is-anim .ps16__card { opacity: 1; animation: none; }
	}

	@media (max-width: 860px) {
		.ps16__head { grid-template-columns: 1fr; }
		.ps16__grid { grid-template-columns: 1fr 1fr; }
	}
	@media (max-width: 540px) {
		.ps16__grid { grid-template-columns: 1fr; }
	}
</style>

<script>
	// Reveal the grid when it scrolls into view (cards animate from the centre
	// out via per-card CSS delays). Per-instance guard + astro:page-load.
	function initPs16(root: HTMLElement) {
		if (root.dataset.ps16Init) return;
		root.dataset.ps16Init = "1";
		if (window.matchMedia?.("(prefers-reduced-motion: reduce)").matches) return;
		root.classList.add("is-anim");
		const reveal = () => root.classList.add("is-in");
		if (!("IntersectionObserver" in window)) return reveal();
		const io = new IntersectionObserver(
			(entries, obs) => {
				for (const e of entries) if (e.isIntersecting) { reveal(); obs.disconnect(); }
			},
			{ threshold: 0.15 },
		);
		io.observe(root);
	}
	function initAllPs16() {
		document.querySelectorAll<HTMLElement>(".ps16").forEach(initPs16);
	}
	document.addEventListener("astro:page-load", initAllPs16);
	initAllPs16();
</script>
