---
import type { Services7Props } from "./schema";
import PeakSection from "../PeakSection.astro";

const node = (Astro.props.node ?? {}) as Services7Props;
const { title, cards, cardColor = "#fbf9f6" } = node;

const cardList = Array.isArray(cards) ? cards.filter((c) => c?.title || c?.image) : [];
---

<PeakSection node={node}>
	<div class="ps7" style={`--card:${cardColor}`}>
		{title && <h2 class="ps7__title">{title}</h2>}

		{cardList.length > 0 && (
			<div class="ps7__grid">
				{cardList.map((c, i) => (
					<article class="ps7__card">
						<span class="ps7__num">{String(i + 1).padStart(2, "0")}</span>
						{c.title && <h3 class="ps7__card-title">{c.title}</h3>}
						{c.description && <p class="ps7__card-text">{c.description}</p>}
						{c.image && (
							<div class="ps7__media">
								<img src={c.image} alt={c.alt ?? c.title ?? ""} loading="lazy" />
							</div>
						)}
					</article>
				))}
			</div>
		)}
	</div>
</PeakSection>

<style>
	.ps7 { color: #15161a; }

	.ps7__title {
		text-align: center;
		margin: 0 0 clamp(2rem, 4vw, 3.5rem);
		font-weight: 800;
		letter-spacing: -0.03em;
		font-size: calc(clamp(2.4rem, 5vw, 4rem) * var(--peak-font-scale, 1));
	}

	.ps7__grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: clamp(1.25rem, 2.5vw, 2rem);
	}
	.ps7__card {
		background: linear-gradient(180deg, #ffffff, var(--card));
		border-radius: 22px;
		padding: clamp(1.5rem, 2.2vw, 2.25rem);
		box-shadow: 0 22px 50px -34px rgba(20, 18, 16, 0.4);
	}
	.ps7__num {
		display: block;
		font-weight: 800;
		font-size: calc(1.3rem * var(--peak-font-scale, 1));
		color: #c2bcb4;
		letter-spacing: 0.02em;
	}
	.ps7__card-title {
		margin: 1.1rem 0 0;
		font-weight: 800;
		letter-spacing: -0.02em;
		font-size: calc(clamp(1.5rem, 2vw, 2rem) * var(--peak-font-scale, 1));
	}
	.ps7__card-text {
		margin: 0.9rem 0 0;
		color: #5c5f66;
		font-size: calc(1.05rem * var(--peak-font-scale, 1));
		line-height: 1.5;
	}
	.ps7__media {
		margin-top: clamp(1.25rem, 2vw, 1.75rem);
		border-radius: 16px;
		overflow: hidden;
		aspect-ratio: 1 / 1;
		background: #ece7e1;
	}
	.ps7__media img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.5s ease;
	}
	.ps7__card:hover .ps7__media img { transform: scale(1.04); }

	/* Staggered entrance. Gated behind .is-anim (added by JS only) so no-JS and
	   reduced-motion render the final state. col 1 loads in place; col 2 rises
	   slowly from the bottom; col 3 snaps up fast, just after. Uses a keyframe
	   (not a 2-state transition) so it plays reliably regardless of frame timing;
	   `both` fill holds each card hidden through its delay. */
	@keyframes ps7-rise {
		from { opacity: 0; transform: translateY(var(--ps7-rise, 64px)); }
		to { opacity: 1; transform: none; }
	}
	.ps7.is-anim .ps7__card { opacity: 0; will-change: opacity, transform; }
	.ps7.is-anim.is-in .ps7__card {
		animation: ps7-rise var(--ps7-dur, 0.6s) var(--ps7-ease, ease) var(--ps7-delay, 0s) both;
	}
	.ps7.is-anim .ps7__card:nth-child(1) { --ps7-rise: 14px; --ps7-dur: 0.45s; --ps7-delay: 0s; }
	.ps7.is-anim .ps7__card:nth-child(2) { --ps7-rise: 72px; --ps7-dur: 1.15s; --ps7-ease: cubic-bezier(0.22, 1, 0.36, 1); --ps7-delay: 0.2s; }
	.ps7.is-anim .ps7__card:nth-child(3) { --ps7-rise: 72px; --ps7-dur: 0.4s; --ps7-ease: cubic-bezier(0.22, 1, 0.36, 1); --ps7-delay: 1.05s; }
	.ps7.is-anim .ps7__card:nth-child(n + 4) { --ps7-dur: 0.5s; --ps7-delay: 1.2s; }
	@media (prefers-reduced-motion: reduce) {
		.ps7.is-anim .ps7__card { opacity: 1; animation: none; }
	}

	@media (max-width: 880px) {
		.ps7__grid { grid-template-columns: 1fr; max-width: 460px; margin-inline: auto; }
	}
</style>

<script>
	// Scroll-triggered staggered entrance. Per-instance guard + astro:page-load
	// re-init. Skips entirely under reduced-motion (final state stays visible).
	function initPs7(root: HTMLElement) {
		if (root.dataset.ps7Init) return;
		root.dataset.ps7Init = "1";
		if (window.matchMedia?.("(prefers-reduced-motion: reduce)").matches) return;
		root.classList.add("is-anim");
		const reveal = () => root.classList.add("is-in");
		if (!("IntersectionObserver" in window)) {
			reveal();
			return;
		}
		const io = new IntersectionObserver(
			(entries, obs) => {
				for (const e of entries) {
					if (e.isIntersecting) {
						reveal();
						obs.disconnect();
					}
				}
			},
			{ threshold: 0.2 },
		);
		io.observe(root);
	}
	function initAllPs7() {
		document.querySelectorAll<HTMLElement>(".ps7").forEach(initPs7);
	}
	document.addEventListener("astro:page-load", initAllPs7);
	initAllPs7();
</script>
