---
import type { Hero18Props } from "./schema";
import PeakSection from "../PeakSection.astro";

const node = (Astro.props.node ?? {}) as Hero18Props;
const {
	badge, title, body, buttonText, buttonUrl, image, imageAlt,
	tags, statValue, statLabel, avatars,
	insightLabel, insightCta, insightCtaUrl, insightTitle, insightBody, insightStat,
	doctorsValue, doctorsLabel, doctorImage, doctorImageAlt,
} = node;
const tagList = Array.isArray(tags) ? tags.filter((t) => t?.label) : [];
const avatarList = Array.isArray(avatars) ? avatars.filter((a) => a?.url).slice(0, 4) : [];
---

<PeakSection node={node}>
	<div class="hx">
		{image && <img class="hx__bg" src={image} alt={imageAlt ?? ""} loading="eager" />}
		<div class="hx__shade"></div>

		<div class="hx__grid">
			<div class="hx__main">
				{badge && <span class="hx__badge"><span class="hx__badge-ico">✲</span>{badge}</span>}
				{title && <h1 class="hx__title">{title}</h1>}
				{body && <p class="hx__body">{body}</p>}
				{buttonText && <a class="hx__btn" href={buttonUrl}>{buttonText}</a>}

				{(statValue || statLabel) && (
					<div class="hx__stat">
						<div class="hx__stat-top">
							<strong class="hx__stat-value">{statValue}</strong>
							{statLabel && <span class="hx__stat-label">{statLabel}</span>}
						</div>
						{avatarList.length > 0 && (
							<div class="hx__avatars">
								<span class="hx__avatar-stack">{avatarList.map((a) => <img src={a.url} alt="" />)}</span>
								<span class="hx__avatar-ico" aria-hidden="true">⤬</span>
							</div>
						)}
					</div>
				)}
			</div>

			<div class="hx__side">
				{tagList.length > 0 && (
					<div class="hx__tags">{tagList.map((t) => <span class="hx__tag">{t.label}</span>)}</div>
				)}

				<div class="hx__cards">
					<div class="hx__card hx__card--insight">
						<div class="hx__card-head">
							<span class="hx__crown" aria-hidden="true">♛</span>
							{insightLabel && <span class="hx__card-label">{insightLabel}</span>}
							{insightCta && <a class="hx__chip" href={insightCtaUrl}>{insightCta}</a>}
						</div>
						{insightTitle && <h3 class="hx__card-title">{insightTitle}</h3>}
						{insightBody && <p class="hx__card-body">{insightBody}</p>}
						<div class="hx__card-foot">
							{insightStat && <strong class="hx__card-stat">{insightStat}</strong>}
							<span class="hx__dots" aria-hidden="true">⠿</span>
						</div>
					</div>

					<div class="hx__card hx__card--doctors">
						<div class="hx__doc-head">
							{doctorsValue && <strong class="hx__doc-value">{doctorsValue}</strong>}
							{doctorsLabel && <span class="hx__doc-label">{doctorsLabel}</span>}
						</div>
						<div class="hx__doc-arc"></div>
						{doctorImage && <img class="hx__doc-img" src={doctorImage} alt={doctorImageAlt ?? ""} loading="lazy" />}
					</div>
				</div>
			</div>
		</div>
	</div>
</PeakSection>

<style>
	.hx { position: relative; overflow: hidden; border-radius: 28px; min-height: clamp(620px, 88vh, 980px); color: #fff; }
	.hx__bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
	.hx__shade { position: absolute; inset: 0; background: linear-gradient(100deg, rgba(150,180,185,0.92) 0%, rgba(150,180,185,0.45) 38%, rgba(120,150,160,0.12) 62%, rgba(60,80,90,0.25) 100%); }

	.hx__grid { position: relative; display: grid; grid-template-columns: 1.05fr 1fr; gap: 1.5rem; min-height: inherit; padding: clamp(1.75rem, 3.5vw, 3.25rem); }
	.hx__main { display: flex; flex-direction: column; }

	.hx__badge { display: inline-flex; align-items: center; gap: 0.55rem; align-self: flex-start; padding: 0.5rem 1.1rem; border-radius: 999px; background: rgba(255,255,255,0.22); backdrop-filter: blur(6px); font-size: 0.95rem; }
	.hx__badge-ico { opacity: 0.9; }
	.hx__title { font-size: calc(clamp(2.8rem, 5.5vw, 5rem) * var(--peak-font-scale, 1)); font-weight: 500; line-height: 1.02; letter-spacing: -0.01em; margin: 1.75rem 0 0; }
	.hx__body { font-size: calc(1.2rem * var(--peak-font-scale, 1)); line-height: 1.5; margin: 1.5rem 0 0; max-width: 28rem; opacity: 0.95; }
	.hx__btn { align-self: flex-start; margin-top: 2rem; padding: 1rem 2.25rem; border-radius: 999px; background: #fff; color: #1a2a2e; font-weight: 600; text-decoration: none; }

	.hx__stat { margin-top: auto; max-width: 26rem; padding: 1.5rem 1.75rem; border-radius: 22px; background: rgba(255,255,255,0.16); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.18); }
	.hx__stat-top { display: flex; align-items: center; gap: 1.25rem; }
	.hx__stat-value { font-size: 2.6rem; font-weight: 600; line-height: 1; }
	.hx__stat-label { font-size: 1.05rem; line-height: 1.3; opacity: 0.92; }
	.hx__avatars { display: flex; align-items: center; gap: 1rem; margin-top: 1.25rem; }
	.hx__avatar-stack { display: flex; }
	.hx__avatar-stack img { width: 44px; height: 44px; border-radius: 50%; object-fit: cover; border: 2px solid rgba(255,255,255,0.85); margin-left: -12px; }
	.hx__avatar-stack img:first-child { margin-left: 0; }
	.hx__avatar-ico { font-size: 1.4rem; opacity: 0.85; }

	.hx__side { position: relative; display: flex; flex-direction: column; justify-content: flex-end; align-items: flex-end; gap: 1.5rem; }
	.hx__tags { display: flex; flex-wrap: wrap; justify-content: flex-end; gap: 0.6rem; max-width: 30rem; }
	.hx__tag { padding: 0.55rem 1.1rem; border-radius: 999px; background: rgba(255,255,255,0.22); backdrop-filter: blur(6px); font-size: 0.95rem; white-space: nowrap; }

	.hx__cards { display: grid; grid-template-columns: 1.15fr 1fr; gap: 1rem; width: 100%; max-width: 34rem; }
	.hx__card { background: #fff; color: #1a2330; border-radius: 22px; overflow: hidden; }
	.hx__card--insight { padding: 1.4rem 1.5rem; display: flex; flex-direction: column; }
	.hx__card-head { display: flex; align-items: center; gap: 0.6rem; }
	.hx__crown { display: inline-flex; align-items: center; justify-content: center; width: 34px; height: 34px; border-radius: 50%; background: #f7c45a; color: #fff; font-size: 0.95rem; }
	.hx__card-label { font-weight: 600; }
	.hx__chip { margin-left: auto; padding: 0.4rem 1rem; border: 1px solid #e0e3e8; border-radius: 999px; font-size: 0.85rem; color: #1a2330; text-decoration: none; }
	.hx__card-title { font-size: 1.45rem; font-weight: 700; line-height: 1.15; margin: 1.5rem 0 0; }
	.hx__card-body { font-size: 0.95rem; line-height: 1.45; color: #66707d; margin: 0.85rem 0 0; }
	.hx__card-foot { display: flex; align-items: center; justify-content: space-between; margin-top: auto; padding-top: 1.25rem; }
	.hx__card-stat { font-size: 2rem; font-weight: 700; }
	.hx__dots { color: #b8bfc8; font-size: 1.4rem; }

	.hx__card--doctors { position: relative; min-height: 260px; }
	.hx__doc-head { position: absolute; top: 1.2rem; left: 1.3rem; z-index: 2; }
	.hx__doc-value { display: block; font-size: 1.9rem; font-weight: 700; line-height: 1; }
	.hx__doc-label { font-size: 0.95rem; color: #66707d; }
	.hx__doc-arc { position: absolute; left: -20%; right: -20%; top: 46%; height: 46px; background: #ec3a2f; transform: rotate(-14deg); z-index: 1; }
	.hx__doc-img { position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); width: 90%; height: 70%; object-fit: cover; object-position: top center; z-index: 2; }

	@media (max-width: 1080px) {
		.hx__grid { grid-template-columns: 1fr; }
		.hx__side { align-items: stretch; }
		.hx__tags, .hx__cards { max-width: none; justify-content: flex-start; }
	}
	@media (max-width: 620px) {
		.hx__cards { grid-template-columns: 1fr; }
	}
</style>
