---
/**
 * Dev-only block preview page. Auto-discovers every block that exports a
 * `sample` from blocks/<Name>/sample.ts and renders it wrapped in a
 * [data-block="<type>"] element, with its sample data inlined as JSON.
 *
 * The make-section script (scripts/peak/make-section.mjs) drives this page:
 * it screenshots each [data-block] and reads the JSON to build the Section
 * content + the demo page. Single source of truth = sample.ts. Not linked
 * anywhere; safe to leave in the tree.
 */
const samples = import.meta.glob("../peak/blocks/*/sample.ts", { eager: true }) as Record<
	string,
	{ sample: Record<string, unknown> }
>;
const comps = import.meta.glob("../peak/blocks/*/*.astro", { eager: true }) as Record<
	string,
	{ default: any }
>;

// Pair each sample.ts with its sibling <Name>/<Name>.astro and the schema type.
const schemas = import.meta.glob("../peak/blocks/*/schema.ts", { eager: true }) as Record<
	string,
	{ schema: { type: string } }
>;

const blocks = Object.entries(samples)
	.map(([path, mod]) => {
		const dir = path.slice(0, path.lastIndexOf("/")); // ../peak/blocks/<Name>
		const name = dir.slice(dir.lastIndexOf("/") + 1);
		const Comp = comps[`${dir}/${name}.astro`]?.default;
		const type = schemas[`${dir}/schema.ts`]?.schema?.type;
		return Comp && type ? { name, type, Comp, sample: mod.sample } : null;
	})
	.filter(Boolean) as Array<{ name: string; type: string; Comp: any; sample: Record<string, unknown> }>;

// ?w=full | contained | full-bg  — override every block's width to compare modes.
// Omit ?w to use each block's own default.
const w = Astro.url.searchParams.get("w");
const cw = Astro.url.searchParams.get("cw"); // narrow|medium|wide|full|default
const nodeFor = (sample: Record<string, unknown>) => ({
	...sample,
	...(w ? { width: w } : {}),
	...(cw ? { contentWidth: cw } : {}),
});
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<title>Peak block preview</title>
		<style>
			body { margin: 0; background: #fff; font-family: system-ui, sans-serif; }
			/* In full/full-bg view the wrapper adds no side padding so blocks truly
			   reach the edges; in boxed/default view a little framing helps. */
			[data-block] { padding-block: 40px; }
			[data-block]:not(.is-edge) { padding-inline: 40px; background: #5a5046; }
			.ppv-bar {
				position: sticky; top: 0; z-index: 1000; display: flex; gap: 0.5rem; align-items: center;
				padding: 0.6rem 1rem; background: #111; color: #fff; font-size: 0.9rem;
			}
			.ppv-bar a {
				padding: 0.35rem 0.8rem; border-radius: 6px; background: #2a2a2a; color: #fff;
				text-decoration: none; font-weight: 600;
			}
			.ppv-bar a.on { background: #4f46e5; }
		</style>
	</head>
	<body>
		<nav class="ppv-bar">
			<span>Width:</span>
			<a href="/peak-preview" class:list={{ on: !w }}>Default</a>
			<a href="/peak-preview?w=full" class:list={{ on: w === "full" }}>Full width</a>
			<a href="/peak-preview?w=full-bg" class:list={{ on: w === "full-bg" }}>Full background</a>
			<a href="/peak-preview?w=contained" class:list={{ on: w === "contained" }}>Boxed</a>
			<span style="margin-left:auto;opacity:.6">{blocks.length} blocks</span>
		</nav>
		{
			blocks.map(({ type, Comp, sample }) => (
				<div data-block={type} class:list={{ "is-edge": w === "full" || w === "full-bg" }}>
					<Comp node={nodeFor(sample)} />
					<script type="application/json" class="peak-sample" set:html={JSON.stringify({ type, node: sample })} />
				</div>
			))
		}
	</body>
</html>
