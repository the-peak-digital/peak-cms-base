---
// Peak username/password login form. The form posts to /api/login, which the
// Cloudflare Worker (src/worker.ts) intercepts — it verifies the password and
// signs you in. (A worker handles it because a root [...slug] catch-all shadows
// POST to Astro routes in this Astro version.)
export const prerender = false;
const error = Astro.url.searchParams.get("error") ? true : false;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>Sign in — Peak</title>
		<style>
			* { box-sizing: border-box; }
			body { margin: 0; min-height: 100vh; display: grid; place-items: center; background: #0f172a; font-family: system-ui, -apple-system, sans-serif; }
			.card { width: 360px; max-width: 92vw; background: #fff; border-radius: 14px; padding: 2rem; box-shadow: 0 24px 60px -20px rgba(0,0,0,.5); }
			h1 { margin: 0 0 0.25rem; font-size: 1.4rem; color: #0f172a; }
			p.sub { margin: 0 0 1.5rem; color: #64748b; font-size: 0.95rem; }
			label { display: block; font-size: 0.85rem; font-weight: 600; color: #334155; margin: 1rem 0 0.4rem; }
			input { width: 100%; padding: 0.7rem 0.85rem; border: 1px solid #cbd5e1; border-radius: 8px; font-size: 1rem; }
			input:focus { outline: 2px solid #4f46e5; border-color: #4f46e5; }
			button { width: 100%; margin-top: 1.5rem; padding: 0.8rem; border: 0; border-radius: 8px; background: #4f46e5; color: #fff; font-weight: 600; font-size: 1rem; cursor: pointer; }
			button:hover { background: #4338ca; }
			.err { margin-top: 1rem; padding: 0.6rem 0.8rem; background: #fef2f2; color: #b91c1c; border-radius: 8px; font-size: 0.9rem; }
			.alt { margin-top: 1.25rem; text-align: center; font-size: 0.85rem; }
			.alt a { color: #4f46e5; text-decoration: none; }
		</style>
	</head>
	<body>
		<form class="card" method="POST" action="/api/login">
			<h1>Sign in</h1>
			<p class="sub">Peak CMS admin</p>
			{error && <div class="err">Incorrect email or password.</div>}
			<label for="email">Email</label>
			<input id="email" name="email" type="email" autocomplete="username" required autofocus />
			<label for="password">Password</label>
			<input id="password" name="password" type="password" autocomplete="current-password" required />
			<button type="submit">Sign in</button>
			<p class="alt"><a href="/_emdash/admin/login">Use a passkey instead</a></p>
		</form>
	</body>
</html>
