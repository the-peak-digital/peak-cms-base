---
/**
 * Public page route — renders any published CMS page by its slug, wrapped in the
 * Peak BaseLayout (header + footer). Each page can choose its header/footer
 * variant and menus via fields (peakHeader, peakFooter, peakHeaderMenu,
 * peakFooterMenu); sensible defaults apply when unset.
 *
 * 404s are rendered through Astro's normal pipeline (NOT a short-circuit
 * `return new Response()`). Returning a raw Response on the authenticated request
 * path poisons keep-alive connections — the next request on the reused browser
 * connection hangs — which froze logged-in browsing right after hitting a 404.
 */
import { getEmDashEntry } from "emdash";
import { PortableText } from "emdash/ui";
import { blockComponents } from "../peak/blocks/registry";
import BaseLayout from "../peak/layouts/BaseLayout.astro";

const { slug } = Astro.params;
const { entry: page } = await getEmDashEntry("pages", slug ?? "");

if (!page) {
	Astro.response.status = 404;
}

const d = (page?.data ?? {}) as Record<string, any>;
const content = d.content ?? [];
// Per-page selection fields are snake_case slugs; tolerate camelCase too.
const pick = (a: string, b: string, fallback: string) => d[a] || d[b] || fallback;
---

{
	page ? (
		<BaseLayout
			title={d.title}
			description={d.meta_description || d.metaDescription}
			header={pick("peak_header", "peakHeader", "default")}
			footer={pick("peak_footer", "peakFooter", "default")}
			headerMenu={pick("peak_header_menu", "peakHeaderMenu", "primary")}
			footerMenu={pick("peak_footer_menu", "peakFooterMenu", "footer")}
		>
			<PortableText value={content} components={{ type: blockComponents as any }} />
		</BaseLayout>
	) : (
		<BaseLayout title="Page not found" header="default" footer="default" headerMenu="primary" footerMenu="footer">
			<section style="max-width:680px;margin:6rem auto;padding:0 1.5rem;text-align:center">
				<h1>Page not found</h1>
				<p>The page you’re looking for doesn’t exist.</p>
				<p><a href="/">Go home</a></p>
			</section>
		</BaseLayout>
	)
}
