---
// Homepage, wrapped in the Peak BaseLayout (header + footer from the CMS menus).
import BaseLayout from "../peak/layouts/BaseLayout.astro";
---

<BaseLayout title="Home">
	<section style="max-width:760px;margin:0 auto;padding:4rem 1.5rem;text-align:center">
		<h1 style="font-size:2.5rem;margin:0 0 1rem">Welcome to Peak</h1>
		<p style="color:var(--peak-muted);font-size:1.15rem">
			Edit content in the <a href="/_emdash/admin">admin panel</a>. Create pages and
			drop in blocks; they render at their slug with this header and footer.
		</p>
	</section>
</BaseLayout>
