# Copy to .env and fill in. With these set, the app uses Postgres + R2.
# Leave them unset to fall back to local SQLite + local uploads (dev).

# --- Railway Postgres ---
# Railway → your Postgres service → "Connect" → Postgres Connection URL.
# Use the public URL for local dev; the internal URL when deployed on Railway.
DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DBNAME

# --- Cloudflare R2 (S3-compatible) ---
# Cloudflare dashboard → R2 → create a bucket, then create an R2 API Token
# (Account-level, Object Read & Write). The token page shows the endpoint + keys.
S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_BUCKET=peak-media
S3_ACCESS_KEY_ID=<R2_ACCESS_KEY_ID>
S3_SECRET_ACCESS_KEY=<R2_SECRET_ACCESS_KEY>
S3_REGION=auto
# Public base URL for serving images. Enable the bucket's r2.dev public URL,
# or attach a custom domain, and put it here (no trailing slash).
S3_PUBLIC_URL=https://<PUBLIC_BUCKET_DOMAIN>
